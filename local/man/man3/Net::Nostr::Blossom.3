.SH NAME
Net::Nostr::Blossom \- NIP\-B7 Blossom media server lists
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 1
\&    use Net::Nostr::Blossom;
\&
\&    # Build a Blossom server list
\&    my $bl = Net::Nostr::Blossom\->new;
\&    $bl\->add(\*(Aqhttps://blossom.self.hosted\*(Aq);
\&    $bl\->add(\*(Aqhttps://cdn.blossom.cloud\*(Aq);
\&
\&    # Convert to a kind 10063 event for publishing
\&    my $event = $bl\->to_event(pubkey => $key\->pubkey_hex);
\&    $key\->sign_event($event);
\&    $client\->publish($event);
\&
\&    # Parse from a received kind 10063 event
\&    my $bl = Net::Nostr::Blossom\->from_event($event);
\&    for my $url ($bl\->servers) {
\&        say $url;
\&    }
\&
\&    # Extract SHA\-256 hash from a Blossom URL
\&    my $url = "https://old\-server.com/${\e(\*(Aqa\*(Aq x 64)}.png";
\&    my ($hash, $ext) = Net::Nostr::Blossom\->extract_hash($url);
\&    # $hash = \*(Aqaaa...aaa\*(Aq (64 hex chars), $ext = \*(Aqpng\*(Aq
\&
\&    # Generate alternative URLs from other Blossom servers
\&    my @urls = Net::Nostr::Blossom\->resolve_urls(
\&        "https://dead\-server.com/${\e(\*(Aqa\*(Aq x 64)}.png",
\&        [\*(Aqhttps://blossom.self.hosted\*(Aq, \*(Aqhttps://cdn.blossom.cloud\*(Aq],
\&    );
\&
\&    # Verify downloaded content matches expected SHA\-256
\&    use Digest::SHA qw(sha256_hex);
\&    my $data = \*(Aqfile contents\*(Aq;
\&    my $expected_hash = sha256_hex($data);
\&    Net::Nostr::Blossom\->verify_sha256($data, $expected_hash);  # true
.Ve
.SH DESCRIPTION
.IX Header "DESCRIPTION"
Implements NIP\-B7 Blossom media integration. Blossom is a set of standards
for dealing with servers that store files addressable by their SHA\-256 hashes.
.PP
Nostr clients SHOULD fetch \f(CW\*(C`kind:10063\*(C'\fR lists of Blossom servers for each
user. When a URL in an event ends with a 64\-character hex string (with or
without a file extension) and is no longer available, clients SHOULD look up
the user\*(Aqs \f(CW\*(C`kind:10063\*(C'\fR server list and try the same hash on alternative
servers.
.PP
When downloading files, clients SHOULD verify that the SHA\-256 hash of the
content matches the 64\-character hex string in the URL.
.SH CONSTRUCTOR
.IX Header "CONSTRUCTOR"
.SS new
.IX Subsection "new"
.Vb 1
\&    my $bl = Net::Nostr::Blossom\->new;
.Ve
.PP
Creates an empty Blossom server list. Croaks on unknown arguments.
.SS from_event
.IX Subsection "from_event"
.Vb 1
\&    my $bl = Net::Nostr::Blossom\->from_event($event);
.Ve
.PP
Parses a kind 10063 event into a Blossom server list. Extracts all
\&\f(CW\*(C`server\*(C'\fR tags and ignores other tag types. Croaks if the event is not
kind 10063.
.PP
.Vb 6
\&    my $event = Net::Nostr::Event\->new(
\&        pubkey => \*(Aqa\*(Aq x 64, kind => 10063, content => \*(Aq\*(Aq,
\&        tags => [[\*(Aqserver\*(Aq, \*(Aqhttps://blossom.example.com\*(Aq]],
\&    );
\&    my $bl = Net::Nostr::Blossom\->from_event($event);
\&    say $bl\->count;  # 1
.Ve
.SH METHODS
.IX Header "METHODS"
.SS add
.IX Subsection "add"
.Vb 1
\&    $bl\->add($url);
.Ve
.PP
Adds a Blossom server URL. If the URL already exists, it is not duplicated.
Returns \f(CW$self\fR for chaining.
.PP
.Vb 2
\&    $bl\->add(\*(Aqhttps://server1.com\*(Aq)
\&       \->add(\*(Aqhttps://server2.com\*(Aq);
.Ve
.SS remove
.IX Subsection "remove"
.Vb 1
\&    $bl\->remove($url);
.Ve
.PP
Removes the server with the given URL. No\-op if not present.
Returns \f(CW$self\fR for chaining.
.SS contains
.IX Subsection "contains"
.Vb 1
\&    my $bool = $bl\->contains($url);
.Ve
.PP
Returns true if the given server URL is in the list.
.PP
.Vb 3
\&    $bl\->add(\*(Aqhttps://blossom.example.com\*(Aq);
\&    say $bl\->contains(\*(Aqhttps://blossom.example.com\*(Aq);  # 1
\&    say $bl\->contains(\*(Aqhttps://other.com\*(Aq);             # 0
.Ve
.SS count
.IX Subsection "count"
.Vb 1
\&    my $n = $bl\->count;
.Ve
.PP
Returns the number of servers in the list.
.SS servers
.IX Subsection "servers"
.Vb 1
\&    my @urls = $bl\->servers;
.Ve
.PP
Returns the list of server URLs in the order they were added.
.SS to_tags
.IX Subsection "to_tags"
.Vb 2
\&    my $tags = $bl\->to_tags;
\&    # [[\*(Aqserver\*(Aq, \*(Aqhttps://blossom.self.hosted\*(Aq], [\*(Aqserver\*(Aq, \*(Aqhttps://cdn.blossom.cloud\*(Aq]]
.Ve
.PP
Returns the server list as an arrayref of tag arrays.
.SS to_event
.IX Subsection "to_event"
.Vb 2
\&    my $event = $bl\->to_event(pubkey => $pubkey_hex);
\&    my $event = $bl\->to_event(pubkey => $pubkey_hex, created_at => time());
.Ve
.PP
Creates a kind 10063 Net::Nostr::Event from the server list. All extra
arguments are passed through to \f(CW\*(C`Net::Nostr::Event\->new\*(C'\fR. The \f(CW\*(C`kind\*(C'\fR,
\&\f(CW\*(C`content\*(C'\fR, and \f(CW\*(C`tags\*(C'\fR fields are set automatically.
.SS extract_hash
.IX Subsection "extract_hash"
.Vb 1
\&    my ($hash, $ext) = Net::Nostr::Blossom\->extract_hash($url);
.Ve
.PP
Extracts a 64\-character hex string (SHA\-256 hash) from a URL. Returns the
hash and optional file extension, or \f(CW\*(C`(undef, undef)\*(C'\fR if the URL does not
contain a recognizable Blossom hash.
.PP
.Vb 5
\&    my ($h, $ext) = Net::Nostr::Blossom\->extract_hash(
\&        \*(Aqhttps://server.com/abc123...def.png\*(Aq
\&    );
\&    # $h   = \*(Aqabc123...def\*(Aq  (64 hex chars)
\&    # $ext = \*(Aqpng\*(Aq
.Ve
.SS resolve_urls
.IX Subsection "resolve_urls"
.Vb 1
\&    my @urls = Net::Nostr::Blossom\->resolve_urls($url, \e@servers);
.Ve
.PP
Given a URL containing a SHA\-256 hash and a list of Blossom server URLs,
generates alternative URLs by combining each server with the hash (and
optional file extension). Returns an empty list if the URL does not contain
a recognizable hash.
.PP
.Vb 6
\&    my @urls = Net::Nostr::Blossom\->resolve_urls(
\&        "https://unavailable.com/${\e (\*(Aqb\*(Aq x 64)}.jpg",
\&        [\*(Aqhttps://blossom.self.hosted\*(Aq, \*(Aqhttps://cdn.blossom.cloud\*(Aq],
\&    );
\&    # (\*(Aqhttps://blossom.self.hosted/bbb...bbb.jpg\*(Aq,
\&    #  \*(Aqhttps://cdn.blossom.cloud/bbb...bbb.jpg\*(Aq)
.Ve
.SS verify_sha256
.IX Subsection "verify_sha256"
.Vb 1
\&    my $ok = Net::Nostr::Blossom\->verify_sha256($data, $expected_hash);
.Ve
.PP
Verifies that the SHA\-256 hash of \f(CW$data\fR matches \f(CW$expected_hash\fR.
Returns true on match, false otherwise. Clients SHOULD call this after
downloading files from Blossom servers.
.PP
.Vb 4
\&    my $data = \*(Aqfile contents\*(Aq;
\&    my $hash = Digest::SHA::sha256_hex($data);
\&    Net::Nostr::Blossom\->verify_sha256($data, $hash);   # true
\&    Net::Nostr::Blossom\->verify_sha256(\*(Aqtampered\*(Aq, $hash);  # false
.Ve
