.SH NAME
Net::Nostr::RelayList \- NIP\-65 relay list metadata
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 1
\&    use Net::Nostr::RelayList;
\&
\&    # Build a relay list
\&    my $rl = Net::Nostr::RelayList\->new;
\&    $rl\->add(\*(Aqwss://alicerelay.example.com\*(Aq);
\&    $rl\->add(\*(Aqwss://expensive\-relay.example2.com\*(Aq, marker => \*(Aqwrite\*(Aq);
\&    $rl\->add(\*(Aqwss://nostr\-relay.example.com\*(Aq, marker => \*(Aqread\*(Aq);
\&
\&    # Query relay categories
\&    my @write = $rl\->write_relays;  # unmarked + write\-marked
\&    my @read  = $rl\->read_relays;   # unmarked + read\-marked
\&
\&    # Convert to a kind 10002 event for publishing
\&    my $event = $rl\->to_event(pubkey => $key\->pubkey_hex);
\&    $key\->sign_event($event);
\&    $client\->publish($event);
\&
\&    # Parse from a received kind 10002 event
\&    my $rl = Net::Nostr::RelayList\->from_event($event);
\&    for my $r ($rl\->relays) {
\&        say "$r\->{url} ($r\->{marker})";
\&    }
.Ve
.SH DESCRIPTION
.IX Header "DESCRIPTION"
Implements NIP\-65 relay list metadata. A relay list is a kind 10002
replaceable event containing \f(CW\*(C`r\*(C'\fR tags, one per relay. Each tag carries
a relay URL and an optional \f(CW\*(C`read\*(C'\fR or \f(CW\*(C`write\*(C'\fR marker. If the marker is
omitted, the relay is used for both reading and writing.
.PP
Clients SHOULD use an author\*(Aqs \fBwrite\fR relays when downloading events
\&\fBfrom\fR that user, and \fBread\fR relays when downloading events \fBabout\fR
that user (where the user was tagged). Clients SHOULD guide users to keep
lists small (2\-4 relays per category).
.SH CONSTRUCTOR
.IX Header "CONSTRUCTOR"
.SS new
.IX Subsection "new"
.Vb 1
\&    my $rl = Net::Nostr::RelayList\->new;
.Ve
.PP
Creates an empty relay list. Croaks on unknown arguments.
.SS from_event
.IX Subsection "from_event"
.Vb 1
\&    my $rl = Net::Nostr::RelayList\->from_event($event);
.Ve
.PP
Parses a kind 10002 event into a RelayList. Extracts all \f(CW\*(C`r\*(C'\fR tags and
ignores other tag types. Croaks if the event is not kind 10002.
.PP
.Vb 6
\&    my $event = Net::Nostr::Event\->new(
\&        pubkey => \*(Aqa\*(Aq x 64, kind => 10002, content => \*(Aq\*(Aq,
\&        tags => [[\*(Aqr\*(Aq, \*(Aqwss://relay.example.com\*(Aq, \*(Aqwrite\*(Aq]],
\&    );
\&    my $rl = Net::Nostr::RelayList\->from_event($event);
\&    say $rl\->count;  # 1
.Ve
.SH METHODS
.IX Header "METHODS"
.SS add
.IX Subsection "add"
.Vb 3
\&    $rl\->add($url);
\&    $rl\->add($url, marker => \*(Aqwrite\*(Aq);
\&    $rl\->add($url, marker => \*(Aqread\*(Aq);
.Ve
.PP
Adds a relay entry. \f(CW\*(C`marker\*(C'\fR must be \f(CW\*(Aqread\*(Aq\fR, \f(CW\*(Aqwrite\*(Aq\fR, or omitted
(meaning both). If the URL already exists, the entry is updated in place.
Returns \f(CW$self\fR for chaining.
.PP
.Vb 2
\&    $rl\->add(\*(Aqwss://relay1.com\*(Aq)
\&       \->add(\*(Aqwss://relay2.com\*(Aq, marker => \*(Aqwrite\*(Aq);
.Ve
.SS remove
.IX Subsection "remove"
.Vb 1
\&    $rl\->remove($url);
.Ve
.PP
Removes the entry for the given URL. No\-op if not present.
Returns \f(CW$self\fR for chaining.
.SS contains
.IX Subsection "contains"
.Vb 1
\&    my $bool = $rl\->contains($url);
.Ve
.PP
Returns true if the given relay URL is in the list.
.PP
.Vb 3
\&    $rl\->add(\*(Aqwss://relay.com\*(Aq);
\&    say $rl\->contains(\*(Aqwss://relay.com\*(Aq);   # 1
\&    say $rl\->contains(\*(Aqwss://other.com\*(Aq);   # 0
.Ve
.SS count
.IX Subsection "count"
.Vb 1
\&    my $n = $rl\->count;
.Ve
.PP
Returns the total number of relays in the list.
.SS relays
.IX Subsection "relays"
.Vb 1
\&    my @relays = $rl\->relays;
.Ve
.PP
Returns the list of relay entries as hashrefs, each with keys
\&\f(CW\*(C`url\*(C'\fR and \f(CW\*(C`marker\*(C'\fR. Entries appear in the order they were added.
.PP
.Vb 3
\&    for my $r ($rl\->relays) {
\&        say "$r\->{url}: $r\->{marker}";
\&    }
.Ve
.SS write_relays
.IX Subsection "write_relays"
.Vb 1
\&    my @urls = $rl\->write_relays;
.Ve
.PP
Returns the URLs of relays the user writes to: those with marker
\&\f(CW\*(Aqwrite\*(Aq\fR or no marker (both). Use these when downloading events
\&\fBfrom\fR the user.
.PP
.Vb 5
\&    $rl\->add(\*(Aqwss://both.example.com\*(Aq);
\&    $rl\->add(\*(Aqwss://w.example.com\*(Aq, marker => \*(Aqwrite\*(Aq);
\&    $rl\->add(\*(Aqwss://r.example.com\*(Aq, marker => \*(Aqread\*(Aq);
\&    my @write = $rl\->write_relays;
\&    # (\*(Aqwss://both.example.com\*(Aq, \*(Aqwss://w.example.com\*(Aq)
.Ve
.SS read_relays
.IX Subsection "read_relays"
.Vb 1
\&    my @urls = $rl\->read_relays;
.Ve
.PP
Returns the URLs of relays the user reads from: those with marker
\&\f(CW\*(Aqread\*(Aq\fR or no marker (both). Use these when downloading events
\&\fBabout\fR the user (where the user was tagged).
.PP
.Vb 5
\&    $rl\->add(\*(Aqwss://both.example.com\*(Aq);
\&    $rl\->add(\*(Aqwss://w.example.com\*(Aq, marker => \*(Aqwrite\*(Aq);
\&    $rl\->add(\*(Aqwss://r.example.com\*(Aq, marker => \*(Aqread\*(Aq);
\&    my @read = $rl\->read_relays;
\&    # (\*(Aqwss://both.example.com\*(Aq, \*(Aqwss://r.example.com\*(Aq)
.Ve
.SS to_tags
.IX Subsection "to_tags"
.Vb 2
\&    my $tags = $rl\->to_tags;
\&    # [[\*(Aqr\*(Aq, \*(Aqwss://relay.com\*(Aq], [\*(Aqr\*(Aq, \*(Aqwss://w.com\*(Aq, \*(Aqwrite\*(Aq], ...]
.Ve
.PP
Returns the relay list as an arrayref of tag arrays, suitable for
passing to "new" in Net::Nostr::Event. The marker is omitted for
relays with no marker.
.SS to_event
.IX Subsection "to_event"
.Vb 2
\&    my $event = $rl\->to_event(pubkey => $pubkey_hex);
\&    my $event = $rl\->to_event(pubkey => $pubkey_hex, created_at => time());
.Ve
.PP
Creates a kind 10002 Net::Nostr::Event from the relay list. All extra
arguments are passed through to \f(CW\*(C`Net::Nostr::Event\->new\*(C'\fR. The
\&\f(CW\*(C`kind\*(C'\fR, \f(CW\*(C`content\*(C'\fR, and \f(CW\*(C`tags\*(C'\fR fields are set automatically.
.PP
.Vb 2
\&    my $event = $rl\->to_event(pubkey => $key\->pubkey_hex);
\&    $key\->sign_event($event);
.Ve
