.SH NAME
Net::Nostr::Label \- NIP\-32 Labeling
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 1
\&    use Net::Nostr::Label;
\&
\&    # Create a kind 1985 label event
\&    my $event = Net::Nostr::Label\->label(
\&        pubkey    => $pubkey,
\&        namespace => \*(Aqcom.example.ontology\*(Aq,
\&        labels    => [\*(AqVI\-hum\*(Aq],
\&        targets   => [[\*(Aqp\*(Aq, $target_pk, $relay]],
\&        content   => \*(AqExplanation of the label\*(Aq,
\&    );
\&
\&    # Build tags for self\-reporting on any event
\&    my $L = Net::Nostr::Label\->namespace_tag(\*(AqISO\-639\-1\*(Aq);
\&    my $l = Net::Nostr::Label\->label_tag(\*(Aqen\*(Aq, \*(AqISO\-639\-1\*(Aq);
\&
\&    # Parse labels from an event
\&    my $info = Net::Nostr::Label\->from_event($event);
\&    my @namespaces = @{$info\->namespaces};
\&    my @labels     = @{$info\->labels};
\&    my @en_labels  = $info\->labels_for(\*(AqISO\-639\-1\*(Aq);
\&
\&    # Check for a specific label
\&    if ($info\->has_label(\*(AqMIT\*(Aq, \*(Aqlicense\*(Aq)) { ... }
\&
\&    # Build a subscription filter
\&    my $filter = Net::Nostr::Label\->label_filter(
\&        namespace => \*(Aqlicense\*(Aq,
\&        labels    => [\*(AqMIT\*(Aq],
\&    );
.Ve
.SH CONSTRUCTOR
.IX Header "CONSTRUCTOR"
.SS new
.IX Subsection "new"
.Vb 5
\&    my $label = Net::Nostr::Label\->new(
\&        namespaces => [\*(AqISO\-639\-1\*(Aq],
\&        labels     => [[\*(Aqen\*(Aq, \*(AqISO\-639\-1\*(Aq]],
\&        targets    => [[\*(Aqe\*(Aq, $event_id, $relay]],
\&    );
.Ve
.PP
Creates a new label object. \f(CW\*(C`namespaces\*(C'\fR, \f(CW\*(C`labels\*(C'\fR, and \f(CW\*(C`targets\*(C'\fR
all default to \f(CW\*(C`[]\*(C'\fR. Croaks on unknown arguments.
.SH DESCRIPTION
.IX Header "DESCRIPTION"
Implements NIP\-32 (Labeling). Provides methods to create kind 1985 label
events, build L/l tags for self\-reporting, parse labels from events, and
build subscription filters.
.SS label
.IX Subsection "label"
.Vb 7
\&    my $event = Net::Nostr::Label\->label(
\&        pubkey    => $pubkey,
\&        namespace => \*(Aqlicense\*(Aq,
\&        labels    => [\*(AqMIT\*(Aq],
\&        targets   => [[\*(Aqe\*(Aq, $event_id, $relay]],
\&        content   => \*(Aqoptional explanation\*(Aq,
\&    );
.Ve
.PP
Creates a kind 1985 label event. \f(CW\*(C`namespace\*(C'\fR is optional; if omitted, the
\&\f(CW\*(C`ugc\*(C'\fR namespace is implied and no L tag is emitted. \f(CW\*(C`targets\*(C'\fR must include
at least one \f(CW\*(C`e\*(C'\fR, \f(CW\*(C`p\*(C'\fR, \f(CW\*(C`a\*(C'\fR, \f(CW\*(C`r\*(C'\fR, or \f(CW\*(C`t\*(C'\fR tag.
.SS namespace_tag
.IX Subsection "namespace_tag"
.Vb 2
\&    my $tag = Net::Nostr::Label\->namespace_tag(\*(AqISO\-639\-1\*(Aq);
\&    # [\*(AqL\*(Aq, \*(AqISO\-639\-1\*(Aq]
.Ve
.PP
Returns an L tag arrayref. Use when building tags for self\-reporting on
non\-1985 events.
.SS label_tag
.IX Subsection "label_tag"
.Vb 2
\&    my $tag = Net::Nostr::Label\->label_tag(\*(Aqen\*(Aq, \*(AqISO\-639\-1\*(Aq);
\&    # [\*(Aql\*(Aq, \*(Aqen\*(Aq, \*(AqISO\-639\-1\*(Aq]
\&
\&    my $tag = Net::Nostr::Label\->label_tag(\*(Aqspam\*(Aq);
\&    # [\*(Aql\*(Aq, \*(Aqspam\*(Aq]
.Ve
.PP
Returns an l tag arrayref. The namespace mark is optional; if omitted,
\&\f(CW\*(C`ugc\*(C'\fR is implied.
.SS from_event
.IX Subsection "from_event"
.Vb 4
\&    my $info = Net::Nostr::Label\->from_event($event);
\&    my @ns     = @{$info\->namespaces};  # L tag values
\&    my @labels = @{$info\->labels};      # [value, mark?] pairs
\&    my @targets = @{$info\->targets};    # target tags
.Ve
.PP
Parses label information from any event (kind 1985 or self\-reported).
Returns a Net::Nostr::Label object with accessors for \f(CW\*(C`namespaces\*(C'\fR,
\&\f(CW\*(C`labels\*(C'\fR, and \f(CW\*(C`targets\*(C'\fR.
.SS labels_for
.IX Subsection "labels_for"
.Vb 1
\&    my @values = $info\->labels_for(\*(AqISO\-639\-1\*(Aq);
.Ve
.PP
Returns label values for a specific namespace.
.SS has_label
.IX Subsection "has_label"
.Vb 2
\&    if ($info\->has_label(\*(AqMIT\*(Aq, \*(Aqlicense\*(Aq)) { ... }
\&    if ($info\->has_label(\*(Aqspam\*(Aq)) { ... }
.Ve
.PP
Returns true if the label set contains the given value, optionally within
the specified namespace.
.SS validate
.IX Subsection "validate"
.Vb 1
\&    Net::Nostr::Label\->validate($event);
.Ve
.PP
Validates a kind 1985 label event. Croaks if the event is not kind 1985,
has no target tags, or has l tag marks that don\*(Aqt match any L namespace.
.SS label_filter
.IX Subsection "label_filter"
.Vb 5
\&    my $filter = Net::Nostr::Label\->label_filter(
\&        namespace => \*(Aqlicense\*(Aq,
\&        labels    => [\*(AqMIT\*(Aq, \*(AqGPL\*(Aq],
\&        authors   => [$pubkey],
\&    );
.Ve
.PP
Returns a subscription filter hashref for querying label events. All
parameters are optional.
.SH ACCESSORS
.IX Header "ACCESSORS"
.SS namespaces
.IX Subsection "namespaces"
Arrayref of L tag values (namespace strings).
.SS labels
.IX Subsection "labels"
Arrayref of \f(CW\*(C`[value, namespace?]\*(C'\fR pairs from l tags.
.SS targets
.IX Subsection "targets"
Arrayref of target tags (\f(CW\*(C`e\*(C'\fR, \f(CW\*(C`p\*(C'\fR, \f(CW\*(C`a\*(C'\fR, \f(CW\*(C`r\*(C'\fR, or \f(CW\*(C`t\*(C'\fR tags).
