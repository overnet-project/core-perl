.SH NAME
Net::Nostr::RemoteSigning \- NIP\-46 Nostr Remote Signing
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 1
\&    use Net::Nostr::RemoteSigning;
\&
\&    my $remote_signer_pubkey = \*(Aqfa984bd7dbb282f07e16e7ae87b26a2a7b9b90b7246a44771f0cf5ae58018f52\*(Aq;
\&    my $client_pubkey        = \*(Aqeff37350d839ce3707332348af4549a96051bd695d3223af4aabce4993531d86\*(Aq;
\&
\&    # Parse a bunker URI (remote\-signer initiated)
\&    my $conn = Net::Nostr::RemoteSigning\->parse_bunker_uri(
\&        "bunker://${remote_signer_pubkey}?relay=wss%3A%2F%2Frelay.example.com&secret=mysecret"
\&    );
\&    say $conn\->remote_signer_pubkey;
\&    say $conn\->relays\->[0];
\&
\&    # Parse a nostrconnect URI (client initiated)
\&    my $nc = Net::Nostr::RemoteSigning\->parse_nostrconnect_uri(
\&        "nostrconnect://${client_pubkey}?relay=wss%3A%2F%2Frelay.example.com&secret=0s8j2djs&name=My+Client"
\&    );
\&    say $nc\->client_pubkey;
\&    say $nc\->secret;
\&
\&    # Build a request payload
\&    my $payload = Net::Nostr::RemoteSigning\->request(
\&        id     => \*(Aqreq\-1\*(Aq,
\&        method => \*(Aqsign_event\*(Aq,
\&        params => [\*(Aq{}\*(Aq],
\&    );
\&
\&    # Build a request event (kind 24133)
\&    my $event = Net::Nostr::RemoteSigning\->request_event(
\&        id                   => \*(Aqreq\-1\*(Aq,
\&        method               => \*(Aqsign_event\*(Aq,
\&        params               => [\*(Aq{}\*(Aq],
\&        pubkey               => $client_pubkey,
\&        remote_signer_pubkey => $remote_signer_pubkey,
\&    );
\&
\&    # Parse a decrypted response
\&    my $json = JSON\->new\->utf8\->encode({ id => \*(Aqreq\-1\*(Aq, result => \*(Aqpong\*(Aq });
\&    my $resp = Net::Nostr::RemoteSigning\->parse_response($json);
\&    if ($resp\->is_auth_challenge) {
\&        # Display $resp\->auth_url to user
\&    } elsif ($resp\->is_error) {
\&        warn $resp\->error;
\&    } else {
\&        say $resp\->result;
\&    }
\&
\&    # Parse permissions
\&    my @perms = Net::Nostr::RemoteSigning\->parse_permissions(
\&        \*(Aqnip44_encrypt,sign_event:4\*(Aq
\&    );
.Ve
.SH DESCRIPTION
.IX Header "DESCRIPTION"
Implements NIP\-46 Nostr Remote Signing, a protocol for 2\-way communication
between a remote signer (bunker) and a Nostr client. The remote signer holds
the user\*(Aqs private keys and signs events on behalf of the client, minimizing
key exposure.
.PP
Both request and response events use kind 24133. The content field is
encrypted using NIP\-44 <https://github.com/nostr-protocol/nips/blob/master/44.md>.
This module handles the payload structure and event creation; the caller is
responsible for encrypting/decrypting the content.
.SS "Connection Flow"
.IX Subsection "Connection Flow"
There are two ways to initiate a connection:
.IP \(bu 4
\&\fBRemote\-signer initiated\fR \- The signer provides a \f(CW\*(C`bunker://\*(C'\fR URI.
The client sends a \f(CW\*(C`connect\*(C'\fR request to the signer via the specified relays.
.IP \(bu 4
\&\fBClient initiated\fR \- The client provides a \f(CW\*(C`nostrconnect://\*(C'\fR URI.
The signer sends a \f(CW\*(C`connect\*(C'\fR response back to the client.
.SS Commands
.IX Subsection "Commands"
\&\f(CW\*(C`connect\*(C'\fR, \f(CW\*(C`sign_event\*(C'\fR, \f(CW\*(C`ping\*(C'\fR, \f(CW\*(C`get_public_key\*(C'\fR, \f(CW\*(C`nip04_encrypt\*(C'\fR,
\&\f(CW\*(C`nip04_decrypt\*(C'\fR, \f(CW\*(C`nip44_encrypt\*(C'\fR, \f(CW\*(C`nip44_decrypt\*(C'\fR, \f(CW\*(C`switch_relays\*(C'\fR.
.SH "CLASS METHODS"
.IX Header "CLASS METHODS"
.SS parse_bunker_uri
.IX Subsection "parse_bunker_uri"
.Vb 1
\&    my $conn = Net::Nostr::RemoteSigning\->parse_bunker_uri($uri_string);
.Ve
.PP
Parses a \f(CW\*(C`bunker://\*(C'\fR connection URI. Returns a "BunkerConnection" object.
Croaks if the URI is malformed or missing the required \f(CW\*(C`relay\*(C'\fR parameter.
The \f(CW\*(C`secret\*(C'\fR parameter is optional.
.SS create_bunker_uri
.IX Subsection "create_bunker_uri"
.Vb 5
\&    my $uri = Net::Nostr::RemoteSigning\->create_bunker_uri(
\&        remote_signer_pubkey => $hex_pubkey,       # required
\&        relay                => $url_or_arrayref,  # required
\&        secret               => $secret_string,    # optional
\&    );
.Ve
.PP
Creates a \f(CW\*(C`bunker://\*(C'\fR URI string.
.SS parse_nostrconnect_uri
.IX Subsection "parse_nostrconnect_uri"
.Vb 1
\&    my $nc = Net::Nostr::RemoteSigning\->parse_nostrconnect_uri($uri_string);
.Ve
.PP
Parses a \f(CW\*(C`nostrconnect://\*(C'\fR connection URI. Returns a "NostrConnect" object.
Croaks if the URI is malformed or missing required parameters (\f(CW\*(C`relay\*(C'\fR,
\&\f(CW\*(C`secret\*(C'\fR).
.SS create_nostrconnect_uri
.IX Subsection "create_nostrconnect_uri"
.Vb 9
\&    my $uri = Net::Nostr::RemoteSigning\->create_nostrconnect_uri(
\&        client_pubkey => $hex_pubkey,              # required
\&        relay         => $url_or_arrayref,         # required
\&        secret        => $secret_string,           # required
\&        perms         => \*(Aqnip44_encrypt,sign_event:4\*(Aq,  # optional
\&        name          => \*(AqMy Client\*(Aq,              # optional
\&        url           => \*(Aqhttps://app.example.com\*(Aq,     # optional
\&        image         => \*(Aqhttps://app.example.com/i.png\*(Aq, # optional
\&    );
.Ve
.PP
Creates a \f(CW\*(C`nostrconnect://\*(C'\fR URI string.
.SS request
.IX Subsection "request"
.Vb 5
\&    my $json = Net::Nostr::RemoteSigning\->request(
\&        id     => \*(Aqreq\-1\*(Aq,    # optional, auto\-generated if omitted
\&        method => \*(Aqping\*(Aq,
\&        params => [],
\&    );
.Ve
.PP
Builds a JSON\-encoded request payload. Croaks if \f(CW\*(C`method\*(C'\fR or \f(CW\*(C`params\*(C'\fR is
missing.
.SS request_event
.IX Subsection "request_event"
.Vb 7
\&    my $event = Net::Nostr::RemoteSigning\->request_event(
\&        id                   => \*(Aqreq\-1\*(Aq,
\&        method               => \*(Aqsign_event\*(Aq,
\&        params               => [$event_json],
\&        pubkey               => $client_pubkey,
\&        remote_signer_pubkey => $remote_signer_pubkey,
\&    );
.Ve
.PP
Creates a kind 24133 request Net::Nostr::Event with the JSON payload as
unencrypted content and a \f(CW\*(C`p\*(C'\fR tag with the remote signer\*(Aqs pubkey. Croaks
if \f(CW\*(C`pubkey\*(C'\fR is missing or not 64\-char lowercase hex.
.SS response
.IX Subsection "response"
.Vb 4
\&    my $json = Net::Nostr::RemoteSigning\->response(
\&        id     => \*(Aqreq\-1\*(Aq,
\&        result => \*(Aqpong\*(Aq,
\&    );
.Ve
.PP
Builds a JSON\-encoded response payload. Croaks if \f(CW\*(C`id\*(C'\fR is missing.
.SS response_event
.IX Subsection "response_event"
.Vb 6
\&    my $event = Net::Nostr::RemoteSigning\->response_event(
\&        id            => \*(Aqreq\-1\*(Aq,
\&        result        => \*(Aqpong\*(Aq,
\&        pubkey        => $remote_signer_pubkey,
\&        client_pubkey => $client_pubkey,
\&    );
.Ve
.PP
Creates a kind 24133 response Net::Nostr::Event with a \f(CW\*(C`p\*(C'\fR tag pointing
to the client\*(Aqs pubkey. Croaks if \f(CW\*(C`pubkey\*(C'\fR is missing or not 64\-char
lowercase hex.
.SS parse_request
.IX Subsection "parse_request"
.Vb 1
\&    my $req = Net::Nostr::RemoteSigning\->parse_request($json);
.Ve
.PP
Parses a decrypted JSON request payload. Returns a "Request" object.
Croaks if \f(CW\*(C`id\*(C'\fR, \f(CW\*(C`method\*(C'\fR, or \f(CW\*(C`params\*(C'\fR is missing, or if \f(CW\*(C`params\*(C'\fR is
not an arrayref.
.SS parse_response
.IX Subsection "parse_response"
.Vb 1
\&    my $resp = Net::Nostr::RemoteSigning\->parse_response($json);
.Ve
.PP
Parses a decrypted JSON response payload. Returns a "Response" object.
Croaks if \f(CW\*(C`id\*(C'\fR is missing.
.SS parse_permissions
.IX Subsection "parse_permissions"
.Vb 1
\&    my @perms = Net::Nostr::RemoteSigning\->parse_permissions($perms_string);
.Ve
.PP
Parses a comma\-separated permission string (e.g. \f(CW\*(Aqnip44_encrypt,sign_event:4\*(Aq\fR).
Returns a list of hashrefs with \f(CW\*(C`method\*(C'\fR and optional \f(CW\*(C`param\*(C'\fR keys.
.SS validate_request
.IX Subsection "validate_request"
.Vb 1
\&    Net::Nostr::RemoteSigning\->validate_request($event);
.Ve
.PP
Validates that a request event is kind 24133 and has a \f(CW\*(C`p\*(C'\fR tag. Croaks on
failure.
.SS validate_response
.IX Subsection "validate_response"
.Vb 1
\&    Net::Nostr::RemoteSigning\->validate_response($event);
.Ve
.PP
Validates that a response event is kind 24133. Croaks on failure.
.SS validate_connect_response
.IX Subsection "validate_connect_response"
.Vb 1
\&    Net::Nostr::RemoteSigning\->validate_connect_response($resp, $expected_secret);
.Ve
.PP
Validates that a connect response contains the expected secret. If no expected
secret is provided, accepts any response (for bunker\-initiated connections
where the result is \f(CW"ack"\fR). Croaks if the secret does not match.
.SS parse_switch_relays
.IX Subsection "parse_switch_relays"
.Vb 1
\&    my $relays = Net::Nostr::RemoteSigning\->parse_switch_relays($result_string);
.Ve
.PP
Parses a \f(CW\*(C`switch_relays\*(C'\fR response result. Returns an arrayref of relay URLs,
or \f(CW\*(C`undef\*(C'\fR if the result is null (indicating no relay change needed).
.SS parse_nip05_metadata
.IX Subsection "parse_nip05_metadata"
.Vb 1
\&    my $meta = Net::Nostr::RemoteSigning\->parse_nip05_metadata($json);
.Ve
.PP
Parses a NIP\-05 \f(CW\*(C`.well\-known/nostr.json\*(C'\fR response containing NIP\-46 metadata.
Returns a "Nip05Metadata" object. Croaks if the response does not contain
a \f(CW\*(C`names._\*(C'\fR field.
.SS parse_discovery_event
.IX Subsection "parse_discovery_event"
.Vb 1
\&    my $disc = Net::Nostr::RemoteSigning\->parse_discovery_event($event);
.Ve
.PP
Parses a NIP\-89 kind 31990 discovery event. Returns a "Discovery" object.
Croaks if the event is not kind 31990 or lacks a \f(CW\*(C`k\*(C'\fR tag with value \f(CW24133\fR.
.SS discovery_event
.IX Subsection "discovery_event"
.Vb 5
\&    my $event = Net::Nostr::RemoteSigning\->discovery_event(
\&        pubkey           => $remote_signer_pubkey,
\&        relays           => [$relay1, $relay2],      # optional
\&        nostrconnect_url => \*(Aqhttps://signer.example.com/<nostrconnect>\*(Aq,  # optional
\&    );
.Ve
.PP
Creates a NIP\-89 kind 31990 discovery Net::Nostr::Event with a \f(CW\*(C`k\*(C'\fR tag
of \f(CW24133\fR. Optionally includes \f(CW\*(C`relay\*(C'\fR and \f(CW\*(C`nostrconnect_url\*(C'\fR tags.
Croaks if \f(CW\*(C`pubkey\*(C'\fR is missing or not 64\-char lowercase hex.
