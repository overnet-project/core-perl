.SH NAME
Bitcoin::Crypto::Transaction::Output \- Bitcoin transaction output instance
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 1
\&        use Bitcoin::Crypto qw(btc_transaction);
\&
\&        my $tx = btc_transaction\->new;
\&
\&        $tx\->add_output(
\&                value => 1234,
