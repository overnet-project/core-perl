.SH NAME
Net::Nostr::FollowList \- NIP\-02 follow list management
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 1
\&    use Net::Nostr::FollowList;
\&
\&    # Build a follow list
\&    my $fl = Net::Nostr::FollowList\->new;
\&    $fl\->add(\*(Aqa\*(Aq x 64, relay => \*(Aqwss://relay.example.com/\*(Aq, petname => \*(Aqalice\*(Aq);
\&    $fl\->add(\*(Aqb\*(Aq x 64, petname => \*(Aqbob\*(Aq);
\&    $fl\->add(\*(Aqc\*(Aq x 64);
\&
\&    # Query
\&    say $fl\->count;                  # 3
\&    say $fl\->contains(\*(Aqa\*(Aq x 64);    # 1
\&
\&    # Remove
\&    $fl\->remove(\*(Aqb\*(Aq x 64);
\&
\&    # Convert to a kind 3 event for publishing
\&    my $event = $fl\->to_event(pubkey => $key\->pubkey_hex);
\&    $key\->sign_event($event);
\&    $client\->publish($event);
\&
\&    # Parse from a received kind 3 event
\&    my $fl = Net::Nostr::FollowList\->from_event($event);
\&    for my $f ($fl\->follows) {
\&        say "$f\->{petname}: $f\->{pubkey} ($f\->{relay})";
\&    }
.Ve
.SH DESCRIPTION
.IX Header "DESCRIPTION"
Implements NIP\-02 follow lists. A follow list is a kind 3 replaceable event
containing \f(CW\*(C`p\*(C'\fR tags, one per followed profile. Each tag carries the
profile\*(Aqs pubkey, an optional relay URL, and an optional petname.
.PP
New follows are appended to the end of the list per NIP\-02 convention.
Re\-adding an existing pubkey updates the entry in place.
.SH CONSTRUCTOR
.IX Header "CONSTRUCTOR"
.SS new
.IX Subsection "new"
.Vb 1
\&    my $fl = Net::Nostr::FollowList\->new;
.Ve
.PP
Creates an empty follow list. Croaks on unknown arguments.
.SS from_event
.IX Subsection "from_event"
.Vb 1
\&    my $fl = Net::Nostr::FollowList\->from_event($event);
.Ve
.PP
Parses a kind 3 event into a FollowList. Extracts all \f(CW\*(C`p\*(C'\fR tags and
ignores other tag types. Croaks if the event is not kind 3.
.PP
.Vb 6
\&    my $event = Net::Nostr::Event\->new(
\&        pubkey => \*(Aqa\*(Aq x 64, kind => 3, content => \*(Aq\*(Aq,
\&        tags => [[\*(Aqp\*(Aq, \*(Aqb\*(Aq x 64, \*(Aqwss://relay.com/\*(Aq, \*(Aqbob\*(Aq]],
\&    );
\&    my $fl = Net::Nostr::FollowList\->from_event($event);
\&    say $fl\->count;  # 1
.Ve
.SH METHODS
.IX Header "METHODS"
.SS add
.IX Subsection "add"
.Vb 2
\&    $fl\->add($pubkey);
\&    $fl\->add($pubkey, relay => \*(Aqwss://relay.com/\*(Aq, petname => \*(Aqalice\*(Aq);
.Ve
.PP
Adds a follow entry. \f(CW$pubkey\fR must be 64\-character lowercase hex.
\&\f(CW\*(C`relay\*(C'\fR and \f(CW\*(C`petname\*(C'\fR default to empty string. If the pubkey already
exists, the entry is updated in place. Returns \f(CW$self\fR for chaining.
.PP
.Vb 2
\&    $fl\->add(\*(Aqa\*(Aq x 64, relay => \*(Aqwss://r.com/\*(Aq)
\&       \->add(\*(Aqb\*(Aq x 64, petname => \*(Aqbob\*(Aq);
.Ve
.SS remove
.IX Subsection "remove"
.Vb 1
\&    $fl\->remove($pubkey);
.Ve
.PP
Removes the entry for the given pubkey. No\-op if not present.
Returns \f(CW$self\fR for chaining.
.SS contains
.IX Subsection "contains"
.Vb 1
\&    my $bool = $fl\->contains($pubkey);
.Ve
.PP
Returns true if the given pubkey is in the follow list.
.PP
.Vb 3
\&    $fl\->add(\*(Aqa\*(Aq x 64);
\&    say $fl\->contains(\*(Aqa\*(Aq x 64);  # 1
\&    say $fl\->contains(\*(Aqb\*(Aq x 64);  # 0
.Ve
.SS count
.IX Subsection "count"
.Vb 1
\&    my $n = $fl\->count;
.Ve
.PP
Returns the number of follows in the list.
.SS follows
.IX Subsection "follows"
.Vb 1
\&    my @follows = $fl\->follows;
.Ve
.PP
Returns the list of follow entries as hashrefs, each with keys
\&\f(CW\*(C`pubkey\*(C'\fR, \f(CW\*(C`relay\*(C'\fR, and \f(CW\*(C`petname\*(C'\fR. Entries appear in the order
they were added.
.PP
.Vb 3
\&    for my $f ($fl\->follows) {
\&        say "$f\->{petname}: $f\->{pubkey}";
\&    }
.Ve
.SS to_tags
.IX Subsection "to_tags"
.Vb 2
\&    my $tags = $fl\->to_tags;
\&    # [[\*(Aqp\*(Aq, \*(Aqaa...\*(Aq, \*(Aqwss://r.com/\*(Aq, \*(Aqalice\*(Aq], ...]
.Ve
.PP
Returns the follow list as an arrayref of tag arrays, suitable for
passing to "new" in Net::Nostr::Event.
.SS to_event
.IX Subsection "to_event"
.Vb 2
\&    my $event = $fl\->to_event(pubkey => $pubkey_hex);
\&    my $event = $fl\->to_event(pubkey => $pubkey_hex, created_at => time());
.Ve
.PP
Creates a kind 3 Net::Nostr::Event from the follow list. All extra
arguments are passed through to \f(CW\*(C`Net::Nostr::Event\->new\*(C'\fR. The
\&\f(CW\*(C`kind\*(C'\fR, \f(CW\*(C`content\*(C'\fR, and \f(CW\*(C`tags\*(C'\fR fields are set automatically.
.PP
.Vb 2
\&    my $event = $fl\->to_event(pubkey => $key\->pubkey_hex);
\&    $key\->sign_event($event);
.Ve
