.SH NAME
Net::Nostr::Filter \- Nostr event filter for subscriptions and queries
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 1
\&    use Net::Nostr::Filter;
\&
\&    my $filter = Net::Nostr::Filter\->new(
\&        kinds   => [1],
\&        authors => [\*(Aqa\*(Aq x 64],
\&        since   => time() \- 3600,
\&        limit   => 50,
\&    );
\&
\&    # Check if an event matches
\&    if ($filter\->matches($event)) { ... }
\&
\&    # Tag filters use #<letter> syntax
\&    my $filter = Net::Nostr::Filter\->new(
\&        \*(Aq#t\*(Aq => [\*(Aqnostr\*(Aq, \*(Aqperl\*(Aq],
\&    );
\&
\&    # Retrieve a tag filter
\&    my $values = $filter\->tag_filter(\*(Aqt\*(Aq);  # [\*(Aqnostr\*(Aq, \*(Aqperl\*(Aq]
\&
\&    # Multiple filters act as OR conditions
\&    my $f1 = Net::Nostr::Filter\->new(kinds => [1]);
\&    my $f2 = Net::Nostr::Filter\->new(kinds => [0]);
\&    if (Net::Nostr::Filter\->matches_any($event, $f1, $f2)) { ... }
.Ve
.SH DESCRIPTION
.IX Header "DESCRIPTION"
Implements Nostr event filtering as defined by NIP\-01, with NIP\-50 search
support. All conditions within a single filter are AND\-ed together. Multiple
filters in a subscription are OR\-ed (use \f(CW\*(C`matches_any\*(C'\fR).
.SH CONSTRUCTOR
.IX Header "CONSTRUCTOR"
.SS new
.IX Subsection "new"
.Vb 12
\&    my $filter = Net::Nostr::Filter\->new(
\&        ids     => [\*(Aqa\*(Aq x 64],
\&        authors => [\*(Aqb\*(Aq x 64],
\&        kinds   => [1, 2],
\&        since   => 1673361254,
\&        until   => 1673361999,
\&        limit   => 100,
\&        search  => \*(Aqbest nostr apps\*(Aq,
\&        \*(Aq#e\*(Aq    => [\*(Aqc\*(Aq x 64],
\&        \*(Aq#p\*(Aq    => [\*(Aqd\*(Aq x 64],
\&        \*(Aq#t\*(Aq    => [\*(Aqnostr\*(Aq],
\&    );
.Ve
.PP
All fields are optional. \f(CW\*(C`ids\*(C'\fR, \f(CW\*(C`authors\*(C'\fR, \f(CW\*(C`#e\*(C'\fR, and \f(CW\*(C`#p\*(C'\fR values must
be 64\-character lowercase hex strings. \f(CW\*(C`kinds\*(C'\fR values must be integers
between 0 and 65535. \f(CW\*(C`since\*(C'\fR, \f(CW\*(C`until\*(C'\fR, and \f(CW\*(C`limit\*(C'\fR must be non\-negative
integers. \f(CW\*(C`search\*(C'\fR must be a plain string (not a reference). Croaks on
invalid values or unknown arguments.
.PP
The \f(CW\*(C`search\*(C'\fR field (NIP\-50) is a human\-readable query string. It may
contain \f(CW\*(C`key:value\*(C'\fR extension pairs (e.g. \f(CW\*(C`language:en\*(C'\fR). See
"parse_search_extensions".
.SH METHODS
.IX Header "METHODS"
.SS matches
.IX Subsection "matches"
.Vb 1
\&    my $bool = $filter\->matches($event);
.Ve
.PP
Returns true if the event matches all conditions in this filter.
When \f(CW\*(C`search\*(C'\fR is set, performs case\-insensitive matching of all search terms
against the event\*(Aqs \f(CW\*(C`content\*(C'\fR field. Extension pairs (\f(CW\*(C`key:value\*(C'\fR) in the
search string are ignored for client\-side matching.
.PP
.Vb 6
\&    my $filter = Net::Nostr::Filter\->new(kinds => [1], since => 1000);
\&    my $event = Net::Nostr::Event\->new(
\&        pubkey => \*(Aqa\*(Aq x 64, kind => 1, content => \*(Aq\*(Aq,
\&        created_at => 2000, tags => [],
\&    );
\&    say $filter\->matches($event);  # 1
\&
\&    # NIP\-50: search matching
\&    my $search_filter = Net::Nostr::Filter\->new(search => \*(Aqnostr apps\*(Aq);
\&    my $note = Net::Nostr::Event\->new(
\&        pubkey => \*(Aqa\*(Aq x 64, kind => 1, content => \*(Aqbest nostr apps for daily use\*(Aq,
\&        created_at => 1000, tags => [],
\&    );
\&    say $search_filter\->matches($note);  # 1
.Ve
.SS matches_any
.IX Subsection "matches_any"
.Vb 1
\&    my $bool = Net::Nostr::Filter\->matches_any($event, @filters);
.Ve
.PP
Class method. Returns true if the event matches any of the given filters
(OR logic).
.SS tag_filter
.IX Subsection "tag_filter"
.Vb 1
\&    my $values = $filter\->tag_filter(\*(Aqt\*(Aq);  # [\*(Aqnostr\*(Aq] or undef
.Ve
.PP
Returns the arrayref of values for a tag filter, or \f(CW\*(C`undef\*(C'\fR if that
tag letter was not specified.
.SS to_hash
.IX Subsection "to_hash"
.Vb 2
\&    my $hash = $filter\->to_hash;
\&    # { kinds => [1], authors => [...], \*(Aq#t\*(Aq => [\*(Aqnostr\*(Aq] }
.Ve
.PP
Returns a hashref suitable for JSON encoding in a REQ message. Only
includes fields that were set.
.SS ids
.IX Subsection "ids"
.Vb 1
\&    my $ids = $filter\->ids;  # arrayref or undef
.Ve
.PP
Event id prefixes to match. Events whose id starts with any of these
hex strings are included.
.SS authors
.IX Subsection "authors"
.Vb 1
\&    my $authors = $filter\->authors;  # arrayref or undef
.Ve
.PP
Pubkey prefixes to match. Events whose pubkey starts with any of these
hex strings are included.
.SS kinds
.IX Subsection "kinds"
.Vb 1
\&    my $kinds = $filter\->kinds;  # arrayref or undef
.Ve
.PP
Event kinds to match. Events with any of these kinds are included.
.SS since
.IX Subsection "since"
.Vb 1
\&    my $since = $filter\->since;  # Unix timestamp or undef
.Ve
.PP
Lower bound (inclusive) on \f(CW\*(C`created_at\*(C'\fR.
.SS until
.IX Subsection "until"
.Vb 1
\&    my $until = $filter\->until;  # Unix timestamp or undef
.Ve
.PP
Upper bound (inclusive) on \f(CW\*(C`created_at\*(C'\fR.
.SS limit
.IX Subsection "limit"
.Vb 1
\&    my $limit = $filter\->limit;  # integer or undef
.Ve
.PP
Maximum number of events to return. Applied after sorting by \f(CW\*(C`created_at\*(C'\fR
descending.
.SS search
.IX Subsection "search"
.Vb 1
\&    my $search = $filter\->search;  # string or undef
.Ve
.PP
NIP\-50 search query string. See "parse_search_extensions" for parsing
extension pairs from the search string.
.SS parse_search_extensions
.IX Subsection "parse_search_extensions"
.Vb 5
\&    my $result = Net::Nostr::Filter\->parse_search_extensions(
\&        \*(Aqbest nostr apps language:en nsfw:false\*(Aq
\&    );
\&    # $result\->{terms}      = [\*(Aqbest\*(Aq, \*(Aqnostr\*(Aq, \*(Aqapps\*(Aq]
\&    # $result\->{extensions} = { language => \*(Aqen\*(Aq, nsfw => \*(Aqfalse\*(Aq }
.Ve
.PP
Class method. Parses a NIP\-50 search string and separates plain search terms
from \f(CW\*(C`key:value\*(C'\fR extension pairs. Returns a hashref with \f(CW\*(C`terms\*(C'\fR (arrayref)
and \f(CW\*(C`extensions\*(C'\fR (hashref).
.PP
Supported extensions defined by NIP\-50: \f(CW\*(C`include:spam\*(C'\fR, \f(CW\*(C`domain:<domain>\*(C'\fR,
\&\f(CW\*(C`language:<code>\*(C'\fR, \f(CW\*(C`sentiment:<value>\*(C'\fR, \f(CW\*(C`nsfw:<bool>\*(C'\fR.
