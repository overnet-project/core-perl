.SH NAME
Net::Nostr::List \- NIP\-51 lists and sets
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 2
\&    use Net::Nostr::List;
\&    use Net::Nostr::Key;
\&
\&    my $key = Net::Nostr::Key\->new;
\&
\&    # Create a mute list (kind 10000) with public and private items
\&    my $mute = Net::Nostr::List\->new(kind => 10000);
\&    $mute\->add(\*(Aqp\*(Aq, $spammer_pubkey);
\&    $mute\->add(\*(Aqt\*(Aq, \*(Aqbitcoin\*(Aq);
\&    $mute\->add(\*(Aqword\*(Aq, \*(Aqgm\*(Aq);
\&    $mute\->add_private(\*(Aqp\*(Aq, $secret_mute_pubkey);
\&
\&    my $event = $mute\->to_event(pubkey => $key\->pubkey_hex, key => $key);
\&    $key\->sign_event($event);
\&    $client\->publish($event);
\&
\&    # Create a pinned notes list (kind 10001)
\&    my $pins = Net::Nostr::List\->new(kind => 10001);
\&    $pins\->add(\*(Aqe\*(Aq, $note_id_1);
\&    $pins\->add(\*(Aqe\*(Aq, $note_id_2);
\&    my $event = $pins\->to_event(pubkey => $key\->pubkey_hex);
\&
\&    # Create a bookmark set (kind 30003) with metadata
\&    my $bookmarks = Net::Nostr::List\->new(kind => 30003, identifier => \*(Aqarticles\*(Aq);
\&    $bookmarks\->title(\*(AqSaved Articles\*(Aq);
\&    $bookmarks\->image(\*(Aqhttps://example.com/books.png\*(Aq);
\&    $bookmarks\->description(\*(AqArticles I want to read later\*(Aq);
\&    $bookmarks\->add(\*(Aqa\*(Aq, "30023:$author:my\-article");
\&    $bookmarks\->add(\*(Aqe\*(Aq, $note_id);
\&
\&    my $event = $bookmarks\->to_event(pubkey => $key\->pubkey_hex);
\&
\&    # Create a relay set (kind 30002)
\&    my $relays = Net::Nostr::List\->new(kind => 30002, identifier => \*(Aqfast\*(Aq);
\&    $relays\->title(\*(AqFast Relays\*(Aq);
\&    $relays\->add(\*(Aqrelay\*(Aq, \*(Aqwss://relay1.com\*(Aq);
\&    $relays\->add(\*(Aqrelay\*(Aq, \*(Aqwss://relay2.com\*(Aq);
\&
\&    # Parse a received list event (public items only)
\&    my $list = Net::Nostr::List\->from_event($event);
\&    for my $item (@{$list\->items}) {
\&        say join(\*(Aq, \*(Aq, @$item);
\&    }
\&
\&    # Parse with decryption of private items
\&    my $list = Net::Nostr::List\->from_event($event, key => $key);
\&    for my $item (@{$list\->private_items}) {
\&        say "private: " . join(\*(Aq, \*(Aq, @$item);
\&    }
.Ve
.SH DESCRIPTION
.IX Header "DESCRIPTION"
Implements NIP\-51 lists. Lists are events whose tags represent references
to things (pubkeys, events, relays, hashtags, etc.). Items can be
\&\fBpublic\fR (in the event tags) or \fBprivate\fR (encrypted in the event
content using NIP\-44).
.PP
There are two categories of lists:
.IP "\fBStandard lists\fR (kinds 10000\-19999)" 4
.IX Item "Standard lists (kinds 10000-19999)"
Replaceable events. A user may only have one list of each kind. Examples:
mute list (10000), pinned notes (10001), bookmarks (10003).
.IP "\fBSets\fR (kinds 30000\-39999)" 4
.IX Item "Sets (kinds 30000-39999)"
Addressable events identified by a \f(CW\*(C`d\*(C'\fR tag. Users can have multiple sets
of each kind. Sets can have optional \f(CW\*(C`title\*(C'\fR, \f(CW\*(C`image\*(C'\fR, and \f(CW\*(C`description\*(C'\fR
tags. Examples: relay sets (30002), curation sets (30004).
.PP
This module is deliberately generic: it accepts any kind and any tag types
without enforcing kind\-specific rules. NIP\-51 defines the list structure,
but individual NIPs (e.g. NIP\-34 for git\-related lists) assign meaning to
specific kind numbers and tag types. Validation of which tags are
appropriate for a given kind is left to the caller.
.SH CONSTRUCTOR
.IX Header "CONSTRUCTOR"
.SS new
.IX Subsection "new"
.Vb 2
\&    my $list = Net::Nostr::List\->new(kind => 10000);
\&    my $set  = Net::Nostr::List\->new(kind => 30002, identifier => \*(Aqmy\-relays\*(Aq);
.Ve
.PP
Creates a new empty list. \f(CW\*(C`kind\*(C'\fR is required. \f(CW\*(C`identifier\*(C'\fR sets the
\&\f(CW\*(C`d\*(C'\fR tag value for sets (defaults to empty string). Croaks on unknown
arguments.
.SS from_event
.IX Subsection "from_event"
.Vb 2
\&    my $list = Net::Nostr::List\->from_event($event);
\&    my $list = Net::Nostr::List\->from_event($event, key => $key);
.Ve
.PP
Parses a list from an existing event. Public items are extracted from
the event tags. If a Net::Nostr::Key is provided, private items
are decrypted from the event content using NIP\-44. Croaks if the
content uses deprecated NIP\-04 encryption.
.PP
.Vb 2
\&    my $list = Net::Nostr::List\->from_event($mute_event, key => $my_key);
\&    say scalar @{$list\->private_items};  # number of privately muted items
.Ve
.SH METHODS
.IX Header "METHODS"
.SS add
.IX Subsection "add"
.Vb 3
\&    $list\->add(\*(Aqp\*(Aq, $pubkey);
\&    $list\->add(\*(Aqrelay\*(Aq, \*(Aqwss://relay.com\*(Aq);
\&    $list\->add(\*(Aqp\*(Aq, $pubkey, \*(Aqwss://hint.com\*(Aq, \*(Aqpetname\*(Aq);
.Ve
.PP
Appends a public item to the list. Arguments become a tag array.
Returns \f(CW$self\fR for chaining. New items are appended to the end
of the list to preserve chronological order.
.PP
.Vb 1
\&    $list\->add(\*(Aqp\*(Aq, $pk1)\->add(\*(Aqp\*(Aq, $pk2)\->add(\*(Aqt\*(Aq, \*(Aqnostr\*(Aq);
.Ve
.SS add_private
.IX Subsection "add_private"
.Vb 2
\&    $list\->add_private(\*(Aqp\*(Aq, $pubkey);
\&    $list\->add_private(\*(Aqword\*(Aq, \*(Aqspam\*(Aq);
.Ve
.PP
Appends a private item to the list. Private items are encrypted
in the event content when \f(CW\*(C`to_event\*(C'\fR is called. Returns \f(CW$self\fR
for chaining.
.PP
.Vb 1
\&    $list\->add_private(\*(Aqp\*(Aq, $secret1)\->add_private(\*(Aqp\*(Aq, $secret2);
.Ve
.SS items
.IX Subsection "items"
.Vb 1
\&    my $items = $list\->items;  # arrayref of arrayrefs
.Ve
.PP
Returns a copy of the public items. Each item is an arrayref
matching the tag structure (e.g. \f(CW\*(C`[\*(Aqp\*(Aq, $pubkey]\*(C'\fR).
.PP
.Vb 3
\&    for my $item (@{$list\->items}) {
\&        say "tag: $item\->[0], value: $item\->[1]";
\&    }
.Ve
.SS private_items
.IX Subsection "private_items"
.Vb 1
\&    my $items = $list\->private_items;  # arrayref of arrayrefs
.Ve
.PP
Returns a copy of the private items. Empty if no private items
exist or if the list was parsed without a decryption key.
.PP
.Vb 4
\&    my $list = Net::Nostr::List\->from_event($event, key => $key);
\&    for my $item (@{$list\->private_items}) {
\&        say "private: $item\->[0] = $item\->[1]";
\&    }
.Ve
.SS kind
.IX Subsection "kind"
.Vb 1
\&    my $kind = $list\->kind;
.Ve
.PP
Returns the event kind for this list.
.SS identifier
.IX Subsection "identifier"
.Vb 2
\&    my $id = $list\->identifier;
\&    $list\->identifier(\*(Aqmy\-set\*(Aq);
.Ve
.PP
Gets or sets the \f(CW\*(C`d\*(C'\fR tag value for sets. Only meaningful for
addressable event kinds (30000\-39999).
.SS title
.IX Subsection "title"
.Vb 2
\&    my $title = $list\->title;
\&    $list\->title(\*(AqMy Collection\*(Aq);
.Ve
.PP
Gets or sets the optional title for sets.
.PP
.Vb 2
\&    my $set = Net::Nostr::List\->new(kind => 30004, identifier => \*(Aqyaks\*(Aq);
\&    $set\->title(\*(AqYaks\*(Aq);
.Ve
.SS image
.IX Subsection "image"
.Vb 2
\&    my $url = $list\->image;
\&    $list\->image(\*(Aqhttps://example.com/pic.png\*(Aq);
.Ve
.PP
Gets or sets the optional image URL for sets.
.SS description
.IX Subsection "description"
.Vb 2
\&    my $desc = $list\->description;
\&    $list\->description(\*(AqA curated collection of yak\-related content\*(Aq);
.Ve
.PP
Gets or sets the optional description for sets.
.SS to_event
.IX Subsection "to_event"
.Vb 2
\&    my $event = $list\->to_event(pubkey => $hex_pubkey);
\&    my $event = $list\->to_event(pubkey => $hex_pubkey, key => $key);
.Ve
.PP
Creates a Net::Nostr::Event from the list. Public items become
event tags. If private items exist, a Net::Nostr::Key must be
provided to encrypt them into the event content using NIP\-44.
Extra arguments are passed through to the Event constructor.
.PP
.Vb 6
\&    my $event = $list\->to_event(
\&        pubkey     => $key\->pubkey_hex,
\&        key        => $key,
\&        created_at => time(),
\&    );
\&    $key\->sign_event($event);
.Ve
