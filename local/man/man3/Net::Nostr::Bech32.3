\&
\&    my $nsec = encode_nsec($privkey_hex);
\&    my $note = encode_note($event_id_hex);
\&
\&    # TLV entities with metadata
\&    my $nprofile = encode_nprofile(
\&        pubkey => $hex_pubkey,
\&        relays => [\*(Aqwss://relay1.com\*(Aq, \*(Aqwss://relay2.com\*(Aq],
\&    );
\&    my $data = decode_nprofile($nprofile);
\&    # { pubkey => \*(Aq...\*(Aq, relays => [\*(Aqwss://relay1.com\*(Aq, \*(Aqwss://relay2.com\*(Aq] }
\&
\&    my $nevent = encode_nevent(
\&        id     => $event_id_hex,
\&        relays => [\*(Aqwss://relay.com\*(Aq],
\&        author => $pubkey_hex,
\&        kind   => 1,
\&    );
\&    my $data = decode_nevent($nevent);
\&    # { id => \*(Aq...\*(Aq, relays => [...], author => \*(Aq...\*(Aq, kind => 1 }
