.SH NAME
WordList::EN::BIP39 \- English word list for BIP 39
.SH VERSION
.IX Header "VERSION"
This document describes version 0.002 of WordList::EN::BIP39 (from Perl distribution WordList\-EN\-BIP39), released on 2020\-09\-14.
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 1
\& use WordList::EN::BIP39;
\&
\& my $wl = WordList::EN::BIP39\->new;
\&
\& # Pick a (or several) random word(s) from the list
\& my $word = $wl\->pick;
\& my @words = $wl\->pick(3);
\&
\& # Check if a word exists in the list
\& if ($wl\->word_exists(\*(Aqfoo\*(Aq)) { ... }
\&
\& # Call a callback for each word
\& $wl\->each_word(sub { my $word = shift; ... });
\&
\& # Iterate
\& my $first_word = $wl\->first_word;
\& while (defined(my $word = $wl\->next_word)) { ... }
\&
\& # Get all the words
\& my @all_words = $wl\->all_words;
.Ve
