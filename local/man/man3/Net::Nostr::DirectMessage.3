.SH NAME
Net::Nostr::DirectMessage \- NIP\-17 private direct messages
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 2
\&    use Net::Nostr::DirectMessage;
\&    use Net::Nostr::Key;
\&
\&    my $sender    = Net::Nostr::Key\->new;
\&    my $recipient = Net::Nostr::Key\->new;
\&
\&    # Create a chat message (kind 14 rumor)
\&    my $msg = Net::Nostr::DirectMessage\->create(
\&        sender_pubkey => $sender\->pubkey_hex,
\&        content       => \*(AqHola, que tal?\*(Aq,
\&        recipients    => [$recipient\->pubkey_hex],
\&        subject       => \*(AqParty\*(Aq,
\&    );
\&
\&    # Wrap for all recipients + sender
\&    my @wraps = Net::Nostr::DirectMessage\->wrap_for_recipients(
\&        rumor      => $msg,
\&        sender_key => $sender,
\&    );
\&    # Publish each wrap to recipient\*(Aqs kind 10050 relays
\&
\&    # Recipient unwraps
\&    my $received = Net::Nostr::DirectMessage\->receive(
\&        event         => $wraps[0],
\&        recipient_key => $recipient,
\&    );
\&    say $received\->content;  # "Hola, que tal?"
\&
\&    # Create a DM relay list (kind 10050)
\&    my $relay_list = Net::Nostr::DirectMessage\->create_relay_list(
\&        pubkey => $sender\->pubkey_hex,
\&        relays => [\*(Aqwss://inbox.nostr.wine\*(Aq, \*(Aqwss://myrelay.nostr1.com\*(Aq],
\&    );
.Ve
.SH DESCRIPTION
.IX Header "DESCRIPTION"
Implements NIP\-17 private direct messages using NIP\-44
encryption and NIP\-59 gift wrapping.
.PP
Messages are created as unsigned kind 14 (chat) or kind 15 (file) events,
then sealed and gift\-wrapped individually for each recipient and the sender.
The gift wrap layer is designed to hide participant identities, timestamps,
and message content from relays and third parties. However, metadata
protection depends on proper usage: relay access patterns, network\-level
metadata, and the \f(CW\*(C`p\*(C'\fR tag on the outer wrap (needed for routing) are
still visible to the relay.
.PP
Other event kinds (e.g. kind 7 reactions) MAY also be gift\-wrapped and
sent to chat participants using the same seal\-and\-wrap mechanism.
.PP
The set of \f(CW\*(C`pubkey\*(C'\fR + \f(CW\*(C`p\*(C'\fR tags defines a chat room. An optional \f(CW\*(C`subject\*(C'\fR
tag sets the conversation topic.
.SH "CLASS METHODS"
.IX Header "CLASS METHODS"
.SS create
.IX Subsection "create"
.Vb 8
\&    my $msg = Net::Nostr::DirectMessage\->create(
\&        sender_pubkey => $pubkey_hex,
\&        content       => \*(AqHello!\*(Aq,
\&        recipients    => [$recipient_pubkey],
\&        subject       => \*(AqOptional topic\*(Aq,     # optional
\&        reply_to      => $parent_event_id,     # optional
\&        quotes        => [[$event_id, $relay, $pubkey]],  # optional
\&    );
.Ve
.PP
Creates a kind 14 chat message as an unsigned rumor. \f(CW\*(C`content\*(C'\fR MUST be
plain text. \f(CW\*(C`recipients\*(C'\fR is an arrayref of pubkey hex strings or
\&\f(CW\*(C`[$pubkey, $relay_url]\*(C'\fR pairs for relay hints.
.PP
\&\f(CW\*(C`reply_to\*(C'\fR can be a plain event ID string or an arrayref
\&\f(CW\*(C`[$event_id, $relay_url]\*(C'\fR for relay hints.
.PP
\&\f(CW\*(C`quotes\*(C'\fR is an optional arrayref of \f(CW\*(C`[$event_id, $relay_url, $pubkey]\*(C'\fR
triples for citing other events via \f(CW\*(C`q\*(C'\fR tags.
.PP
.Vb 6
\&    # Simple recipients
\&    my $msg = Net::Nostr::DirectMessage\->create(
\&        sender_pubkey => $key\->pubkey_hex,
\&        content       => \*(AqHello!\*(Aq,
\&        recipients    => [$bob_pubkey, $carol_pubkey],
\&    );
\&
\&    # With relay hints
\&    my $msg = Net::Nostr::DirectMessage\->create(
\&        sender_pubkey => $key\->pubkey_hex,
\&        content       => \*(AqHello!\*(Aq,
\&        recipients    => [[$bob_pubkey, \*(Aqwss://relay.example.com\*(Aq]],
\&        reply_to      => [$parent_id, \*(Aqwss://relay.example.com\*(Aq],
\&    );
\&
\&    # Quoting another event
\&    my $msg = Net::Nostr::DirectMessage\->create(
\&        sender_pubkey => $key\->pubkey_hex,
\&        content       => \*(Aqcheck this out\*(Aq,
\&        recipients    => [$recipient_pubkey],
\&        quotes        => [[$cited_id, \*(Aqwss://relay.example.com\*(Aq, $cited_pubkey]],
\&    );
.Ve
.SS create_file
.IX Subsection "create_file"
.Vb 10
\&    my $msg = Net::Nostr::DirectMessage\->create_file(
\&        sender_pubkey        => $pubkey_hex,
\&        content              => \*(Aqhttps://example.com/encrypted\-file.bin\*(Aq,
\&        recipients           => [$recipient_pubkey],
\&        file_type            => \*(Aqimage/jpeg\*(Aq,
\&        encryption_algorithm => \*(Aqaes\-gcm\*(Aq,
\&        decryption_key       => $key,
\&        decryption_nonce     => $nonce,
\&        x                    => $sha256_hex,
\&    );
.Ve
.PP
Creates a kind 15 file message as an unsigned rumor. The \f(CW\*(C`content\*(C'\fR is
the file URL. Required tags: \f(CW\*(C`file\-type\*(C'\fR, \f(CW\*(C`encryption\-algorithm\*(C'\fR,
\&\f(CW\*(C`decryption\-key\*(C'\fR, \f(CW\*(C`decryption\-nonce\*(C'\fR, \f(CW\*(C`x\*(C'\fR.
.PP
Optional tags: \f(CW\*(C`ox\*(C'\fR (SHA\-256 of original file), \f(CW\*(C`size\*(C'\fR, \f(CW\*(C`dim\*(C'\fR,
\&\f(CW\*(C`blurhash\*(C'\fR, \f(CW\*(C`thumb\*(C'\fR, \f(CW\*(C`fallback\*(C'\fR (arrayref of fallback URLs),
\&\f(CW\*(C`subject\*(C'\fR (conversation topic).
.PP
\&\f(CW\*(C`recipients\*(C'\fR and \f(CW\*(C`reply_to\*(C'\fR accept relay hints in the same format
as "create". For file replies, use an arrayref with the "reply" marker:
\&\f(CW\*(C`[$event_id, $relay_url, \*(Aqreply\*(Aq]\*(C'\fR.
.PP
.Vb 10
\&    # With all optional tags
\&    my $msg = Net::Nostr::DirectMessage\->create_file(
\&        sender_pubkey        => $key\->pubkey_hex,
\&        content              => \*(Aqhttps://example.com/encrypted\-photo.bin\*(Aq,
\&        recipients           => [$recipient_pubkey],
\&        file_type            => \*(Aqimage/jpeg\*(Aq,
\&        encryption_algorithm => \*(Aqaes\-gcm\*(Aq,
\&        decryption_key       => $key,
\&        decryption_nonce     => $nonce,
\&        x                    => $sha256_hex,
\&        ox                   => $original_sha256,
\&        size                 => \*(Aq2048000\*(Aq,
\&        dim                  => \*(Aq1920x1080\*(Aq,
\&        blurhash             => \*(AqLEHV6nWB2yk8\*(Aq,
\&        thumb                => \*(Aqhttps://example.com/thumb.bin\*(Aq,
\&        fallback             => [\*(Aqhttps://backup.example.com/photo.bin\*(Aq],
\&        subject              => \*(AqVacation photos\*(Aq,
\&    );
.Ve
.SS wrap_for_recipients
.IX Subsection "wrap_for_recipients"
.Vb 4
\&    my @wraps = Net::Nostr::DirectMessage\->wrap_for_recipients(
\&        rumor      => $msg,
\&        sender_key => $key,
\&    );
.Ve
.PP
Seals and gift\-wraps the rumor individually for each recipient (from
\&\f(CW\*(C`p\*(C'\fR tags) and for the sender. Returns a list of kind 1059 events.
.PP
Optional arguments: \f(CW\*(C`expiration\*(C'\fR (add expiration tags for disappearing
messages), \f(CW\*(C`skip_sender\*(C'\fR (omit the sender\*(Aqs copy).
.PP
.Vb 6
\&    # With expiration (disappearing messages)
\&    my @wraps = Net::Nostr::DirectMessage\->wrap_for_recipients(
\&        rumor      => $msg,
\&        sender_key => $key,
\&        expiration => time() + 3600,
\&    );
\&
\&    # Skip the sender\*(Aqs self\-copy
\&    my @wraps = Net::Nostr::DirectMessage\->wrap_for_recipients(
\&        rumor       => $msg,
\&        sender_key  => $key,
\&        skip_sender => 1,
\&    );
.Ve
.SS receive
.IX Subsection "receive"
.Vb 4
\&    my $rumor = Net::Nostr::DirectMessage\->receive(
\&        event         => $gift_wrap,
\&        recipient_key => $key,
\&    );
\&
\&    say $rumor\->kind;     # 14
\&    say $rumor\->content;  # "secret message"
\&    say $rumor\->pubkey;   # sender\*(Aqs pubkey
.Ve
.PP
Unwraps a kind 1059 gift wrap and returns the inner rumor (unsigned event).
The returned rumor preserves all tags including \f(CW\*(C`subject\*(C'\fR.
Verifies that the seal\*(Aqs pubkey matches the rumor\*(Aqs pubkey (required by
NIP\-17). Croaks with "sender pubkey mismatch" if the seal was created by
a different key than the rumor claims, which prevents impersonation attacks.
.PP
\&\fBTrust boundary\fR: This method decrypts and parses the gift wrap structure
and verifies the seal/rumor pubkey consistency. It does \fBnot\fR verify the
gift wrap\*(Aqs Schnorr signature or event ID hash. If you need full
cryptographic verification of the outer event, call
\&\f(CW\*(C`$relay\->_validate_event\*(C'\fR or verify the signature separately before
calling \f(CW\*(C`receive\*(C'\fR.
.SS create_relay_list
.IX Subsection "create_relay_list"
.Vb 4
\&    my $event = Net::Nostr::DirectMessage\->create_relay_list(
\&        pubkey => $pubkey_hex,
\&        relays => [\*(Aqwss://inbox.nostr.wine\*(Aq, \*(Aqwss://myrelay.nostr1.com\*(Aq],
\&    );
.Ve
.PP
Creates a kind 10050 replaceable event listing preferred DM relays.
Tags use the \f(CW\*(C`relay\*(C'\fR tag name (not \f(CW\*(C`r\*(C'\fR). Clients SHOULD keep lists
small (1\-3 relays).
.SS chat_members
.IX Subsection "chat_members"
.Vb 2
\&    my @members = Net::Nostr::DirectMessage\->chat_members($msg);
\&    # @members = ($alice_pubkey, $bob_pubkey)
.Ve
.PP
Returns the list of pubkeys in the chat room defined by the event:
the event\*(Aqs \f(CW\*(C`pubkey\*(C'\fR (the sender) followed by all \f(CW\*(C`p\*(C'\fR\-tagged pubkeys.
The same set of members (regardless of order) defines the same chat room.
