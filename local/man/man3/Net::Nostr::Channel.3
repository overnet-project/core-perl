.SH NAME
Net::Nostr::Channel \- NIP\-28 public chat channels
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 2
\&    use Net::Nostr::Channel;
\&    use Net::Nostr::Key;
\&
\&    my $key = Net::Nostr::Key\->new;
\&
\&    # Create a channel (kind 40)
\&    my $event = Net::Nostr::Channel\->create(
\&        pubkey  => $key\->pubkey_hex,
\&        name    => \*(AqPerl Nostr\*(Aq,
\&        about   => \*(AqDiscussion about Perl and Nostr\*(Aq,
\&        picture => \*(Aqhttps://example.com/perl.png\*(Aq,
\&        relays  => [\*(Aqwss://relay.example.com/\*(Aq],
\&    );
\&    $key\->sign_event($event);
\&    $client\->publish($event);
\&    my $channel_id = $event\->id;
\&
\&    # Update channel metadata (kind 41)
\&    my $update = Net::Nostr::Channel\->set_metadata(
\&        pubkey     => $key\->pubkey_hex,
\&        channel_id => $channel_id,
\&        name       => \*(AqPerl Nostr Chat\*(Aq,
\&        relay_url  => \*(Aqwss://relay.example.com/\*(Aq,
\&        categories => [\*(Aqperl\*(Aq, \*(Aqnostr\*(Aq],
\&    );
\&
\&    # Send a message (kind 42)
\&    my $msg = Net::Nostr::Channel\->message(
\&        pubkey     => $key\->pubkey_hex,
\&        channel_id => $channel_id,
\&        content    => \*(AqHello, channel!\*(Aq,
\&        relay_url  => \*(Aqwss://relay.example.com/\*(Aq,
\&    );
\&
\&    # Reply to a message (kind 42)
\&    my $reply = Net::Nostr::Channel\->reply(
\&        pubkey     => $key\->pubkey_hex,
\&        channel_id => $channel_id,
\&        to         => $msg,
\&        content    => \*(AqWelcome!\*(Aq,
\&    );
\&
\&    # Hide a message (kind 43, client\-side moderation)
\&    my $hide = Net::Nostr::Channel\->hide_message(
\&        pubkey     => $key\->pubkey_hex,
\&        message_id => $msg\->id,
\&        reason     => \*(Aqspam\*(Aq,
\&    );
\&
\&    # Mute a user (kind 44, client\-side moderation)
\&    my $mute = Net::Nostr::Channel\->mute_user(
\&        pubkey      => $key\->pubkey_hex,
\&        user_pubkey => $spammer_pk,
\&        reason      => \*(Aqspammer\*(Aq,
\&    );
\&
\&    # Parse channel metadata from a received event
\&    my $meta = Net::Nostr::Channel\->metadata_from_event($event);
\&    say $meta\->{name};     # \*(AqPerl Nostr\*(Aq
\&    say $meta\->{about};    # \*(AqDiscussion about Perl and Nostr\*(Aq
\&    say $meta\->{picture};  # \*(Aqhttps://example.com/perl.png\*(Aq
\&
\&    # Get channel ID from a message or metadata update
\&    my $ch_id = Net::Nostr::Channel\->channel_id($msg_event);
\&
\&    # Parse hide/mute info from received events
\&    my $hide_info = Net::Nostr::Channel\->hide_from_event($hide_event);
\&    say $hide_info\->{message_id};
\&    say $hide_info\->{reason};  # or undef
\&
\&    my $mute_info = Net::Nostr::Channel\->mute_from_event($mute_event);
\&    say $mute_info\->{pubkey};
\&    say $mute_info\->{reason};  # or undef
.Ve
.SH DESCRIPTION
.IX Header "DESCRIPTION"
Implements NIP\-28 public chat channels. Channels are created with kind 40
events, metadata is updated with kind 41, and messages are sent as kind 42.
Client\-side moderation is provided via kind 43 (hide message) and kind 44
(mute user).
.PP
All moderation is client\-centric: clients decide what content to show or
hide, with no additional requirements on relays.
.SH "CLASS METHODS"
.IX Header "CLASS METHODS"
.SS create
.IX Subsection "create"
.Vb 8
\&    my $event = Net::Nostr::Channel\->create(
\&        pubkey   => $hex_pubkey,
\&        name     => \*(AqChannel Name\*(Aq,
\&        about    => \*(AqDescription\*(Aq,       # optional
\&        picture  => \*(Aqhttps://pic.url\*(Aq,   # optional
\&        relays   => [\*(Aqwss://relay.com\*(Aq], # optional
\&        metadata => { rules => \*(Aq...\*(Aq },  # optional, extra metadata fields
\&    );
.Ve
.PP
Creates a kind 40 channel creation event. The \f(CW\*(C`content\*(C'\fR field is JSON
containing the channel metadata. \f(CW\*(C`name\*(C'\fR is required. \f(CW\*(C`metadata\*(C'\fR is
an optional hashref of additional metadata fields to include in the
JSON content. Extra arguments are passed through to
"new" in Net::Nostr::Event.
.PP
The event ID of the returned event becomes the channel identifier used
by all other methods.
.PP
.Vb 5
\&    my $event = Net::Nostr::Channel\->create(
\&        pubkey => $key\->pubkey_hex,
\&        name   => \*(AqMy Channel\*(Aq,
\&    );
\&    my $channel_id = $event\->id;
.Ve
.SS set_metadata
.IX Subsection "set_metadata"
.Vb 11
\&    my $event = Net::Nostr::Channel\->set_metadata(
\&        pubkey     => $hex_pubkey,
\&        channel_id => $channel_id,
\&        name       => \*(AqNew Name\*(Aq,         # optional
\&        about      => \*(AqNew description\*(Aq,  # optional
\&        picture    => \*(Aqhttps://new.pic\*(Aq,  # optional
\&        relays     => [\*(Aqwss://r.com\*(Aq],    # optional
\&        relay_url  => \*(Aqwss://relay.com/\*(Aq, # optional, defaults to \*(Aq\*(Aq
\&        categories => [\*(Aqtopic1\*(Aq],         # optional, added as t tags
\&        metadata   => { rules => \*(Aq...\*(Aq }, # optional, extra metadata fields
\&    );
.Ve
.PP
Creates a kind 41 channel metadata update event. \f(CW\*(C`channel_id\*(C'\fR is
required. The \f(CW\*(C`e\*(C'\fR tag uses NIP\-10 marked \f(CW\*(C`root\*(C'\fR format. \f(CW\*(C`metadata\*(C'\fR
is an optional hashref of additional metadata fields. Only the most
recent kind 41 per channel should be used.
.PP
Clients should ignore kind 41 events from pubkeys other than the
channel creator.
.PP
.Vb 7
\&    my $update = Net::Nostr::Channel\->set_metadata(
\&        pubkey     => $key\->pubkey_hex,
\&        channel_id => $channel_id,
\&        name       => \*(AqUpdated Name\*(Aq,
\&        categories => [\*(Aqnostr\*(Aq, \*(Aqperl\*(Aq],
\&    );
\&    # tags: [[\*(Aqe\*(Aq, $channel_id, \*(Aq\*(Aq, \*(Aqroot\*(Aq], [\*(Aqt\*(Aq, \*(Aqnostr\*(Aq], [\*(Aqt\*(Aq, \*(Aqperl\*(Aq]]
.Ve
.SS message
.IX Subsection "message"
.Vb 6
\&    my $event = Net::Nostr::Channel\->message(
\&        pubkey     => $hex_pubkey,
\&        channel_id => $channel_id,
\&        content    => \*(AqHello!\*(Aq,
\&        relay_url  => \*(Aqwss://relay.com/\*(Aq,  # optional, defaults to \*(Aq\*(Aq
\&    );
.Ve
.PP
Creates a kind 42 root channel message. The \f(CW\*(C`e\*(C'\fR tag points to the
channel creation event with NIP\-10 \f(CW\*(C`root\*(C'\fR marker.
.PP
.Vb 6
\&    my $msg = Net::Nostr::Channel\->message(
\&        pubkey     => $key\->pubkey_hex,
\&        channel_id => $channel_id,
\&        content    => \*(AqFirst message!\*(Aq,
\&    );
\&    # tags: [[\*(Aqe\*(Aq, $channel_id, \*(Aq\*(Aq, \*(Aqroot\*(Aq]]
.Ve
.SS reply
.IX Subsection "reply"
.Vb 7
\&    my $event = Net::Nostr::Channel\->reply(
\&        pubkey     => $hex_pubkey,
\&        channel_id => $channel_id,
\&        to         => $parent_event,
\&        content    => \*(AqReply text\*(Aq,
\&        relay_url  => \*(Aqwss://relay.com/\*(Aq,  # optional, defaults to \*(Aq\*(Aq
\&    );
.Ve
.PP
Creates a kind 42 reply to a channel message. Has two \f(CW\*(C`e\*(C'\fR tags: one
with \f(CW\*(C`root\*(C'\fR marker pointing to the channel, and one with \f(CW\*(C`reply\*(C'\fR
marker pointing to the parent message. A \f(CW\*(C`p\*(C'\fR tag for the parent
author is appended unless replying to self.
.PP
.Vb 9
\&    my $reply = Net::Nostr::Channel\->reply(
\&        pubkey     => $key\->pubkey_hex,
\&        channel_id => $channel_id,
\&        to         => $msg,
\&        content    => \*(AqI agree!\*(Aq,
\&    );
\&    # tags: [[\*(Aqe\*(Aq, $channel_id, \*(Aq\*(Aq, \*(Aqroot\*(Aq],
\&    #        [\*(Aqe\*(Aq, $msg\->id, \*(Aq\*(Aq, \*(Aqreply\*(Aq],
\&    #        [\*(Aqp\*(Aq, $msg\->pubkey, \*(Aq\*(Aq]]
.Ve
.SS hide_message
.IX Subsection "hide_message"
.Vb 5
\&    my $event = Net::Nostr::Channel\->hide_message(
\&        pubkey     => $hex_pubkey,
\&        message_id => $msg_event_id,
\&        reason     => \*(Aqspam\*(Aq,  # optional
\&    );
.Ve
.PP
Creates a kind 43 event indicating the user no longer wants to see the
specified message. \f(CW\*(C`reason\*(C'\fR is optional; when provided, the \f(CW\*(C`content\*(C'\fR
is JSON \f(CW\*(C`{"reason":"..."}\*(C'\fR.
.PP
Clients should hide kind 42 events if there is a matching kind 43 from
the user. Clients may also hide for other users based on multiple hide
events.
.PP
.Vb 5
\&    my $hide = Net::Nostr::Channel\->hide_message(
\&        pubkey     => $key\->pubkey_hex,
\&        message_id => $msg\->id,
\&        reason     => \*(Aqoff\-topic\*(Aq,
\&    );
.Ve
.SS mute_user
.IX Subsection "mute_user"
.Vb 5
\&    my $event = Net::Nostr::Channel\->mute_user(
\&        pubkey      => $hex_pubkey,
\&        user_pubkey => $target_pubkey,
\&        reason      => \*(Aqspammer\*(Aq,  # optional
\&    );
.Ve
.PP
Creates a kind 44 event indicating the user no longer wants to see
messages from the specified user. \f(CW\*(C`reason\*(C'\fR is optional; when provided,
the \f(CW\*(C`content\*(C'\fR is JSON \f(CW\*(C`{"reason":"..."}\*(C'\fR.
.PP
Clients should hide kind 42 events from the muted pubkey if there is
a matching kind 44 from the user.
.PP
.Vb 5
\&    my $mute = Net::Nostr::Channel\->mute_user(
\&        pubkey      => $key\->pubkey_hex,
\&        user_pubkey => $spammer,
\&        reason      => \*(Aqposting spam\*(Aq,
\&    );
.Ve
.SS metadata_from_event
.IX Subsection "metadata_from_event"
.Vb 2
\&    my $meta = Net::Nostr::Channel\->metadata_from_event($event);
\&    # { name => \*(Aq...\*(Aq, about => \*(Aq...\*(Aq, picture => \*(Aq...\*(Aq, relays => [...] }
.Ve
.PP
Parses channel metadata from a kind 40 or kind 41 event. Returns a
hashref decoded from the event\*(Aqs JSON content. Fields not present in
the content will not be in the hashref. Croaks if the event is not
kind 40 or 41.
.PP
.Vb 2
\&    my $meta = Net::Nostr::Channel\->metadata_from_event($channel_event);
\&    say $meta\->{name};
.Ve
.SS channel_id
.IX Subsection "channel_id"
.Vb 1
\&    my $id = Net::Nostr::Channel\->channel_id($event);  # or undef
.Ve
.PP
Extracts the channel ID (the kind 40 event ID) from a kind 41 or kind 42
event by finding the \f(CW\*(C`e\*(C'\fR tag with \f(CW\*(C`root\*(C'\fR marker. Returns \f(CW\*(C`undef\*(C'\fR if
no root \f(CW\*(C`e\*(C'\fR tag is found.
.PP
.Vb 2
\&    my $ch_id = Net::Nostr::Channel\->channel_id($msg_event);
\&    # the event ID of the kind 40 channel creation event
.Ve
.SS hide_from_event
.IX Subsection "hide_from_event"
.Vb 2
\&    my $info = Net::Nostr::Channel\->hide_from_event($event);
\&    # { message_id => \*(Aq...\*(Aq, reason => \*(Aq...\*(Aq or undef }
.Ve
.PP
Parses a kind 43 event. Returns a hashref with \f(CW\*(C`message_id\*(C'\fR (from the
\&\f(CW\*(C`e\*(C'\fR tag) and \f(CW\*(C`reason\*(C'\fR (from the JSON content, or \f(CW\*(C`undef\*(C'\fR). Croaks
if the event is not kind 43.
.PP
.Vb 3
\&    my $info = Net::Nostr::Channel\->hide_from_event($hide_event);
\&    say "Hidden: $info\->{message_id}";
\&    say "Reason: $info\->{reason}" if $info\->{reason};
.Ve
.SS mute_from_event
.IX Subsection "mute_from_event"
.Vb 2
\&    my $info = Net::Nostr::Channel\->mute_from_event($event);
\&    # { pubkey => \*(Aq...\*(Aq, reason => \*(Aq...\*(Aq or undef }
.Ve
.PP
Parses a kind 44 event. Returns a hashref with \f(CW\*(C`pubkey\*(C'\fR (from the
\&\f(CW\*(C`p\*(C'\fR tag) and \f(CW\*(C`reason\*(C'\fR (from the JSON content, or \f(CW\*(C`undef\*(C'\fR). Croaks
if the event is not kind 44.
.PP
.Vb 3
\&    my $info = Net::Nostr::Channel\->mute_from_event($mute_event);
\&    say "Muted: $info\->{pubkey}";
\&    say "Reason: $info\->{reason}" if $info\->{reason};
.Ve
