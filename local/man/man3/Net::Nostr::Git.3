.SH NAME
Net::Nostr::Git \- NIP\-34 git collaboration over Nostr
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 1
\&    use Net::Nostr::Git;
\&
\&    # Announce a repository
\&    my $repo = Net::Nostr::Git\->repository(
\&        pubkey      => $my_pubkey,
\&        id          => \*(Aqmy\-project\*(Aq,
\&        name        => \*(AqMy Project\*(Aq,
\&        description => \*(AqA Nostr library\*(Aq,
\&        clone       => [\*(Aqhttps://github.com/user/repo.git\*(Aq],
\&        relays      => [\*(Aqwss://relay.example.com\*(Aq],
\&    );
\&
\&    # Announce repository state
\&    my $state = Net::Nostr::Git\->repository_state(
\&        pubkey => $my_pubkey,
\&        id     => \*(Aqmy\-project\*(Aq,
\&        refs   => [
\&            [\*(Aqrefs/heads/main\*(Aq, $commit_id],
\&            [\*(Aqrefs/tags/v1.0\*(Aq,  $tag_commit_id],
\&        ],
\&        head => \*(Aqmain\*(Aq,
\&    );
\&
\&    # Submit a patch
\&    my $patch = Net::Nostr::Git\->patch(
\&        pubkey     => $my_pubkey,
\&        content    => $git_format_patch_output,
\&        repository => "30617:$owner_pk:my\-project",
\&        repo_owner => $owner_pk,
\&        root       => 1,
\&    );
\&
\&    # Open a pull request
\&    my $pr = Net::Nostr::Git\->pull_request(
\&        pubkey     => $my_pubkey,
\&        content    => \*(AqPlease review these changes.\*(Aq,
\&        repository => "30617:$owner_pk:my\-project",
\&        subject    => \*(AqAdd feature X\*(Aq,
\&        commit     => $tip_commit_id,
\&        clone      => [\*(Aqhttps://github.com/user/fork.git\*(Aq],
\&    );
\&
\&    # File an issue
\&    my $issue = Net::Nostr::Git\->issue(
\&        pubkey     => $my_pubkey,
\&        content    => \*(AqFound a bug in parsing.\*(Aq,
\&        repository => "30617:$owner_pk:my\-project",
\&        repo_owner => $owner_pk,
\&        subject    => \*(AqCrash on startup\*(Aq,
\&        labels     => [\*(Aqbug\*(Aq],
\&    );
\&
\&    # Set status
\&    my $status = Net::Nostr::Git\->status(
\&        pubkey        => $my_pubkey,
\&        status        => \*(Aqapplied\*(Aq,
\&        target        => $patch_event_id,
\&        repo_owner    => $my_pubkey,
\&        target_author => $author_pk,
\&    );
\&
\&    # Update a pull request
\&    my $update = Net::Nostr::Git\->pull_request_update(
\&        pubkey     => $my_pubkey,
\&        repository => "30617:$owner_pk:my\-project",
\&        pr_event   => $pr_event_id,
\&        pr_author  => $pr_author_pk,
\&        commit     => $new_tip_commit_id,
\&        clone      => [\*(Aqhttps://github.com/user/fork.git\*(Aq],
\&    );
\&
\&    # User grasp list
\&    my $list = Net::Nostr::Git\->grasp_list(
\&        pubkey  => $my_pubkey,
\&        servers => [\*(Aqwss://grasp.example.com\*(Aq],
\&    );
\&
\&    # Parse any NIP\-34 event
\&    my $info = Net::Nostr::Git\->from_event($event);
\&    say $info\->event_type;  # \*(Aqrepository\*(Aq, \*(Aqpatch\*(Aq, \*(Aqissue\*(Aq, etc.
\&
\&    # Validate a NIP\-34 event
\&    Net::Nostr::Git\->validate($event);
.Ve
.SH DESCRIPTION
.IX Header "DESCRIPTION"
Implements NIP\-34 git collaboration over Nostr. Provides methods to create
all NIP\-34 event kinds: repository announcements, repository state, patches,
pull requests, pull request updates, issues, status events, and user grasp
lists.
.PP
Replies to patches, PRs, and issues follow NIP\-22 comment threading (see
Net::Nostr::Comment).
.SH CONSTRUCTOR
.IX Header "CONSTRUCTOR"
.SS new
.IX Subsection "new"
.Vb 1
\&    my $info = Net::Nostr::Git\->new(%fields);
.Ve
.PP
Creates a new \f(CW\*(C`Net::Nostr::Git\*(C'\fR object.  Typically returned by
"from_event"; calling \f(CW\*(C`new\*(C'\fR directly is useful for testing or
manual construction.
.PP
.Vb 4
\&    my $info = Net::Nostr::Git\->new(
\&        event_type => \*(Aqrepository\*(Aq,
\&        repo_id    => \*(Aqmy\-project\*(Aq,
\&    );
.Ve
.PP
Accepted fields: \f(CW\*(C`event_type\*(C'\fR, \f(CW\*(C`repo_id\*(C'\fR, \f(CW\*(C`repo_name\*(C'\fR,
\&\f(CW\*(C`repo_description\*(C'\fR, \f(CW\*(C`web\*(C'\fR, \f(CW\*(C`clone_urls\*(C'\fR, \f(CW\*(C`relay_urls\*(C'\fR,
\&\f(CW\*(C`earliest_unique_commit\*(C'\fR, \f(CW\*(C`maintainer_pubkeys\*(C'\fR,
\&\f(CW\*(C`repository_address\*(C'\fR, \f(CW\*(C`subject\*(C'\fR, \f(CW\*(C`status_name\*(C'\fR, \f(CW\*(C`grasp_servers\*(C'\fR.
Croaks on unknown arguments.
.SH "CLASS METHODS"
.IX Header "CLASS METHODS"
.SS repository
.IX Subsection "repository"
.Vb 10
\&    my $event = Net::Nostr::Git\->repository(
\&        pubkey              => $hex_pubkey,
\&        id                  => \*(Aqrepo\-id\*(Aq,          # required, becomes d tag
\&        name                => \*(AqHuman Name\*(Aq,       # optional
\&        description         => \*(AqDescription\*(Aq,      # optional
\&        web                 => [\*(Aqhttps://...\*(Aq],     # optional, multiple values
\&        clone               => [\*(Aqhttps://...git\*(Aq],  # optional, multiple values
\&        relays              => [\*(Aqwss://...\*(Aq],       # optional, multiple values
\&        earliest_unique_commit => $commit_hex,      # optional, r tag with euc
\&        maintainers         => [$pubkey, ...],      # optional, multiple values
\&        personal_fork       => 1,                   # optional, adds t:personal\-fork
\&        hashtags            => [\*(Aqtag1\*(Aq, \*(Aqtag2\*(Aq],    # optional
\&    );
.Ve
.PP
Creates a kind 30617 (addressable) repository announcement event.
Only \f(CW\*(C`pubkey\*(C'\fR and \f(CW\*(C`id\*(C'\fR are required; all other tags are optional per spec.
.PP
The \f(CW\*(C`web\*(C'\fR, \f(CW\*(C`clone\*(C'\fR, \f(CW\*(C`relays\*(C'\fR, and \f(CW\*(C`maintainers\*(C'\fR tags support multiple
values passed as arrayrefs.
.SS repository_state
.IX Subsection "repository_state"
.Vb 9
\&    my $event = Net::Nostr::Git\->repository_state(
\&        pubkey => $hex_pubkey,
\&        id     => \*(Aqrepo\-id\*(Aq,
\&        refs   => [
\&            [\*(Aqrefs/heads/main\*(Aq, $commit_id],
\&            [\*(Aqrefs/heads/dev\*(Aq,  $commit_id, $parent_short, $grandparent_short],
\&        ],
\&        head => \*(Aqmain\*(Aq,  # optional, becomes HEAD tag
\&    );
.Ve
.PP
Creates a kind 30618 (addressable) repository state event. The \f(CW\*(C`d\*(C'\fR tag
matches the corresponding repository announcement.
.PP
Each ref is an arrayref of \f(CW\*(C`[ref\-path, commit\-id, ...]\*(C'\fR. Additional elements
after the commit ID are optional shorthand ancestor commits for client use.
.PP
If no \f(CW\*(C`refs\*(C'\fR are provided, the author signals they are no longer tracking
state.
.SS patch
.IX Subsection "patch"
.Vb 10
\&    my $event = Net::Nostr::Git\->patch(
\&        pubkey     => $hex_pubkey,
\&        content    => $git_format_patch_output,
\&        repository => \*(Aq30617:<owner\-pk>:<repo\-id>\*(Aq,
\&        repo_owner => $owner_pk,              # optional p tag
\&        notify     => [$other_pk],            # optional additional p tags
\&        earliest_unique_commit => $commit_id, # optional r tag
\&        root       => 1,                      # optional t:root for first patch
\&        root_revision => 1,                   # optional t:root\-revision
\&        previous_patch => $event_id,          # optional NIP\-10 e reply tag
\&        previous_patch_relay => \*(Aqwss://...\*(Aq,  # optional relay hint for e tag
\&        commit        => $commit_id,          # optional stable commit id
\&        parent_commit => $commit_id,          # optional
\&        commit_pgp_sig => \*(Aq...\*(Aq,              # optional
\&        committer => [$name, $email, $ts, $tz],  # optional
\&    );
.Ve
.PP
Creates a kind 1617 patch event. Content should be the output of
\&\f(CW\*(C`git format\-patch\*(C'\fR. The first patch in a series MAY be a cover letter
in the format produced by \f(CW\*(C`git format\-patch \-\-cover\-letter\*(C'\fR.
.PP
Set \f(CW\*(C`root\*(C'\fR for the first patch in a series. Set \f(CW\*(C`root_revision\*(C'\fR for the
first patch in a revision. Use \f(CW\*(C`previous_patch\*(C'\fR (with optional
\&\f(CW\*(C`previous_patch_relay\*(C'\fR) for NIP\-10 \f(CW\*(C`e\*(C'\fR reply threading within a patch
series.
.SS pull_request
.IX Subsection "pull_request"
.Vb 10
\&    my $event = Net::Nostr::Git\->pull_request(
\&        pubkey      => $hex_pubkey,
\&        content     => \*(AqMarkdown description\*(Aq,
\&        repository  => \*(Aq30617:<owner\-pk>:<repo\-id>\*(Aq,
\&        subject     => \*(AqPR title\*(Aq,            # optional
\&        commit      => $tip_commit_id,        # required, c tag
\&        clone       => [\*(Aqhttps://...git\*(Aq],    # required, at least one
\&        repo_owner  => $owner_pk,             # optional p tag
\&        notify      => [$other_pk],           # optional
\&        labels      => [\*(Aqenhancement\*(Aq],       # optional t tags
\&        branch_name => \*(Aqfeature\-x\*(Aq,           # optional
\&        revises     => $root_patch_event_id,  # optional e tag
\&        merge_base  => $commit_id,            # optional
\&        earliest_unique_commit => $commit_id, # optional r tag
\&    );
.Ve
.PP
Creates a kind 1618 pull request event. \f(CW\*(C`commit\*(C'\fR and \f(CW\*(C`clone\*(C'\fR are required.
.SS pull_request_update
.IX Subsection "pull_request_update"
.Vb 12
\&    my $event = Net::Nostr::Git\->pull_request_update(
\&        pubkey     => $hex_pubkey,
\&        repository => \*(Aq30617:<owner\-pk>:<repo\-id>\*(Aq,
\&        pr_event   => $pr_event_id,       # E tag
\&        pr_author  => $pr_author_pk,      # P tag
\&        commit     => $new_tip_commit_id, # c tag
\&        clone      => [\*(Aqhttps://...git\*(Aq], # clone tag
\&        repo_owner => $owner_pk,          # optional
\&        notify     => [$other_pk],        # optional
\&        merge_base => $commit_id,         # optional
\&        earliest_unique_commit => $cid,   # optional r tag
\&    );
.Ve
.PP
Creates a kind 1619 pull request update event with NIP\-22 \f(CW\*(C`E\*(C'\fR and \f(CW\*(C`P\*(C'\fR
tags pointing to the original PR.
.SS issue
.IX Subsection "issue"
.Vb 8
\&    my $event = Net::Nostr::Git\->issue(
\&        pubkey     => $hex_pubkey,
\&        content    => \*(AqMarkdown bug report\*(Aq,
\&        repository => \*(Aq30617:<owner\-pk>:<repo\-id>\*(Aq,
\&        repo_owner => $owner_pk,           # optional
\&        subject    => \*(AqIssue title\*(Aq,       # optional
\&        labels     => [\*(Aqbug\*(Aq, \*(Aqcritical\*(Aq], # optional t tags
\&    );
.Ve
.PP
Creates a kind 1621 issue event with Markdown content. Issues may
optionally include a \f(CW\*(C`subject\*(C'\fR tag and one or more \f(CW\*(C`t\*(C'\fR label tags.
.SS status
.IX Subsection "status"
.Vb 10
\&    my $event = Net::Nostr::Git\->status(
\&        pubkey        => $hex_pubkey,
\&        status        => \*(Aqopen\*(Aq,          # open|applied|merged|resolved|closed|draft
\&        target        => $event_id,       # e root tag
\&        repo_owner    => $owner_pk,       # p tag
\&        target_author => $author_pk,      # p tag
\&        content            => \*(AqOptional note\*(Aq,    # optional, markdown
\&        accepted_revision  => $event_id,          # optional, e reply tag
\&        revision_author    => $pk,                # optional, p tag
\&        repository         => $repo_coord,        # optional, a tag
\&        repository_relay   => \*(Aqwss://...\*(Aq,        # optional, relay hint
\&        earliest_unique_commit => $commit_id,     # optional, r tag
\&        applied_patches    => [{id => $eid, relay_url => $r, pubkey => $pk}],  # optional (1631)
\&        merge_commit       => $commit_id,         # optional (1631)
\&        applied_as_commits => [$cid1, $cid2],     # optional (1631)
\&    );
.Ve
.PP
Creates a status event: kind 1630 (Open), 1631 (Applied/Merged/Resolved),
1632 (Closed), or 1633 (Draft).
.PP
Per spec, the most recent status event (by \f(CW\*(C`created_at\*(C'\fR) from either the
issue/patch author or a maintainer is considered the current status. The
status of a patch\-revision inherits from its root\-patch, or becomes Closed
(1632) if the root\-patch is Applied/Merged (1631) and the revision is not
tagged in the Applied event.
.SS grasp_list
.IX Subsection "grasp_list"
.Vb 4
\&    my $event = Net::Nostr::Git\->grasp_list(
\&        pubkey  => $hex_pubkey,
\&        servers => [\*(Aqwss://grasp1.com\*(Aq, \*(Aqwss://grasp2.com\*(Aq],
\&    );
.Ve
.PP
Creates a kind 10317 (replaceable) user grasp list event with \f(CW\*(C`g\*(C'\fR tags
for grasp server URLs in order of preference. \f(CW\*(C`servers\*(C'\fR is optional;
zero or more grasp server URLs may be provided.
.SS from_event
.IX Subsection "from_event"
.Vb 1
\&    my $info = Net::Nostr::Git\->from_event($event);
.Ve
.PP
Parses a NIP\-34 event and returns a \f(CW\*(C`Net::Nostr::Git\*(C'\fR object with
appropriate accessors populated, or \f(CW\*(C`undef\*(C'\fR if the event is not a
NIP\-34 kind.
.PP
.Vb 3
\&    say $info\->event_type;  # \*(Aqrepository\*(Aq, \*(Aqpatch\*(Aq, \*(Aqissue\*(Aq, etc.
\&    say $info\->repo_id;     # for repository/state events
\&    say $info\->subject;     # for PR/issue events
.Ve
.SS validate
.IX Subsection "validate"
.Vb 1
\&    Net::Nostr::Git\->validate($event);
.Ve
.PP
Validates that an event is a well\-formed NIP\-34 event. Croaks if
required tags are missing for the given kind. Returns 1 on success.
.PP
.Vb 2
\&    eval { Net::Nostr::Git\->validate($event) };
\&    warn "Invalid: $@" if $@;
.Ve
