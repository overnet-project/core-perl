\&    my $pk = \*(Aq7e7e9c42a91bfef19fa929e5fda1b72e0ebc1a4c1141673e2794234d86addf4e\*(Aq;
\&    my $id = \*(Aqaaf9dd42b3de2a1a2f95e50fdbbef66e1afb165152a581a3ee75ac39a0559cd2\*(Aq;
\&
\&    # Create mentions for use in event content
\&    my $m1 = mention_pubkey($pk);
\&    # nostr:npub1...
\&
\&    my $m2 = mention_pubkey($pk, relays => [\*(Aqwss://relay.com\*(Aq]);
\&    # nostr:nprofile1...
\&
\&    my $m3 = mention_event($id);
\&    # nostr:note1...
\&
