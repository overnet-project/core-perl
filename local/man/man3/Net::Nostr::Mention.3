\&    my $content = "hello $m1 see also $m3";
\&    my @mentions = extract_mentions($content);
\&    # @mentions = ({ type => \*(Aqnpub\*(Aq, data => $pk, uri => \*(Aqnostr:npub1...\*(Aq, ... },
\&    #              { type => \*(Aqnote\*(Aq, data => $id, uri => \*(Aqnostr:note1...\*(Aq, ... })
\&
