.SH NAME
Net::Nostr::Mention \- NIP\-27 text note references
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 4
\&    use Net::Nostr::Mention qw(
\&        extract_mentions replace_mentions
\&        mention_pubkey mention_event mention_addr
\&    );
