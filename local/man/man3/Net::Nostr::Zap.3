.SH NAME
Net::Nostr::Zap \- NIP\-57 Lightning Zaps
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 5
\&    use Net::Nostr::Zap qw(
\&        lud16_to_url encode_lnurl decode_lnurl
\&        bolt11_amount callback_url calculate_splits
\&    );
\&    use Net::Nostr::Key;
\&
\&    my $key = Net::Nostr::Key\->new;
\&
\&    # Create a zap request (kind 9734)
\&    my $zap_req = Net::Nostr::Zap\->new_request(
\&        p      => $recipient_pubkey,
\&        relays => [\*(Aqwss://relay.example.com\*(Aq],
\&        amount => \*(Aq21000\*(Aq,
\&        lnurl  => encode_lnurl(\*(Aqhttps://example.com/.well\-known/lnurlp/alice\*(Aq),
\&        e      => $event_id,
\&        k      => \*(Aq1\*(Aq,
\&    );
\&    my $event = $zap_req\->to_event(pubkey => $key\->pubkey_hex);
\&    $key\->sign_event($event);
\&
\&    # Send zap request to recipient\*(Aqs LNURL callback
\&    my $url = callback_url(\*(Aqhttps://lnurl.example.com/callback\*(Aq,
\&        amount => 21000,
\&        nostr  => $event,
\&        lnurl  => $zap_req\->lnurl,
\&    );
\&
\&    # Parse a received zap request
\&    my $req = Net::Nostr::Zap\->request_from_event($event);
\&    say $req\->p;        # recipient pubkey
\&    say $req\->amount;   # \*(Aq21000\*(Aq
\&
\&    # Create a zap receipt (kind 9735)
\&    my $zap_receipt = Net::Nostr::Zap\->new_receipt(
\&        p           => $recipient_pubkey,
\&        bolt11      => $bolt11_invoice,
\&        description => $zap_request_json,
\&        sender      => $sender_pubkey,
\&        e           => $event_id,
\&        preimage    => $preimage_hex,
\&    );
\&    my $receipt_event = $zap_receipt\->to_event(pubkey => $server_pubkey);
\&
\&    # Parse a received zap receipt
\&    my $receipt = Net::Nostr::Zap\->receipt_from_event($receipt_event);
\&    say $receipt\->bolt11;
\&    my $embedded_req = $receipt\->zap_request;  # Net::Nostr::Event
\&
\&    # Validate a zap request (Appendix D)
\&    Net::Nostr::Zap\->validate_request($event);
\&    Net::Nostr::Zap\->validate_request($event, amount => 21000);
\&
\&    # Validate a zap receipt (Appendix F)
\&    Net::Nostr::Zap\->validate_receipt($receipt_event,
\&        nostr_pubkey => $expected_pubkey,
\&    );
\&
\&    # Convert lightning address to LNURL pay endpoint URL
\&    my $pay_url = lud16_to_url(\*(Aqalice@example.com\*(Aq);
\&    # https://example.com/.well\-known/lnurlp/alice
\&
\&    # Parse bolt11 invoice amount in millisats
\&    my $msats = bolt11_amount(\*(Aqlnbc10u1p3unwfu...\*(Aq);  # 1_000_000
\&
\&    # Calculate zap splits from zap tags (Appendix G)
\&    my @splits = calculate_splits(@zap_tags);
\&    for my $split (@splits) {
\&        say "$split\->{pubkey}: $split\->{percentage}%";
\&    }
.Ve
.SH DESCRIPTION
.IX Header "DESCRIPTION"
Implements NIP\-57 Lightning Zaps, which defines two event types for recording
lightning payments between Nostr users:
.IP \(bu 4
\&\fBZap request\fR (kind 9734) \- Created by the sender and sent to the
recipient\*(Aqs LNURL pay callback URL (not published to relays).
.IP \(bu 4
\&\fBZap receipt\fR (kind 9735) \- Created by the recipient\*(Aqs lightning
wallet when the invoice is paid, and published to relays.
.SH CONSTRUCTORS
.IX Header "CONSTRUCTORS"
.SS new_request
.IX Subsection "new_request"
.Vb 10
\&    my $zap = Net::Nostr::Zap\->new_request(
\&        p       => $recipient_pubkey,   # required
\&        relays  => \e@relay_urls,        # required
\&        amount  => \*(Aq21000\*(Aq,             # millisats, recommended
\&        lnurl   => \*(Aqlnurl1...\*(Aq,        # recommended
\&        e       => $event_id,           # optional, if zapping an event
\&        a       => \*(Aq30023:pk:slug\*(Aq,     # optional, for addressable events
\&        k       => \*(Aq1\*(Aq,                 # optional, target event kind
\&        content => \*(AqGreat post!\*(Aq,       # optional message
\&    );
.Ve
.PP
Creates a zap request. \f(CW\*(C`p\*(C'\fR (recipient pubkey) and \f(CW\*(C`relays\*(C'\fR are required.
.SS new_receipt
.IX Subsection "new_receipt"
.Vb 10
\&    my $zap = Net::Nostr::Zap\->new_receipt(
\&        p           => $recipient_pubkey,    # required
\&        bolt11      => $invoice,             # required
\&        description => $zap_request_json,    # required
\&        sender      => $sender_pubkey,       # optional (P tag)
\&        e           => $event_id,            # optional
\&        a           => \*(Aq30023:pk:slug\*(Aq,      # optional
\&        k           => \*(Aq1\*(Aq,                  # optional
\&        preimage    => $preimage_hex,        # optional
\&    );
.Ve
.PP
Creates a zap receipt. \f(CW\*(C`p\*(C'\fR, \f(CW\*(C`bolt11\*(C'\fR, and \f(CW\*(C`description\*(C'\fR are required. The
\&\f(CW\*(C`description\*(C'\fR must be the JSON\-encoded zap request event.
.SS request_from_event
.IX Subsection "request_from_event"
.Vb 1
\&    my $zap = Net::Nostr::Zap\->request_from_event($event);
.Ve
.PP
Parses a kind 9734 event into a Zap object. Croaks if the event is not
kind 9734.
.PP
.Vb 3
\&    my $zap = Net::Nostr::Zap\->request_from_event($event);
\&    say $zap\->p;       # recipient pubkey
\&    say $zap\->amount;  # millisats or undef
.Ve
.SS receipt_from_event
.IX Subsection "receipt_from_event"
.Vb 1
\&    my $zap = Net::Nostr::Zap\->receipt_from_event($event);
.Ve
.PP
Parses a kind 9735 event into a Zap object. Croaks if the event is not
kind 9735.
.PP
.Vb 3
\&    my $zap = Net::Nostr::Zap\->receipt_from_event($receipt_event);
\&    say $zap\->bolt11;       # bolt11 invoice
\&    say $zap\->description;  # JSON zap request
.Ve
.SH METHODS
.IX Header "METHODS"
.SS to_event
.IX Subsection "to_event"
.Vb 2
\&    my $event = $zap\->to_event(pubkey => $hex_pubkey);
\&    my $event = $zap\->to_event(pubkey => $hex, created_at => time());
.Ve
.PP
Creates a Net::Nostr::Event from the zap object. Extra arguments are
passed through to the Event constructor.
.PP
For zap requests, creates a kind 9734 event. For zap receipts, creates a
kind 9735 event with empty content.
.PP
.Vb 2
\&    my $event = $zap_req\->to_event(pubkey => $key\->pubkey_hex);
\&    $key\->sign_event($event);
.Ve
.SS zap_request
.IX Subsection "zap_request"
.Vb 1
\&    my $event = $zap_receipt\->zap_request;
.Ve
.PP
Parses the \f(CW\*(C`description\*(C'\fR tag of a zap receipt back into a
Net::Nostr::Event object representing the original zap request.
Only available on receipt objects.
.PP
.Vb 3
\&    my $receipt = Net::Nostr::Zap\->receipt_from_event($event);
\&    my $req = $receipt\->zap_request;
\&    say $req\->pubkey;  # the sender\*(Aqs pubkey
.Ve
.SS p
.IX Subsection "p"
.Vb 1
\&    my $pubkey = $zap\->p;
.Ve
.PP
Returns the recipient\*(Aqs pubkey (from the \f(CW\*(C`p\*(C'\fR tag).
.SS relays
.IX Subsection "relays"
.Vb 1
\&    my $relays = $zap\->relays;  # arrayref
.Ve
.PP
Returns the relay URLs (zap request only).
.SS amount
.IX Subsection "amount"
.Vb 1
\&    my $msats = $zap\->amount;  # \*(Aq21000\*(Aq or undef
.Ve
.PP
Returns the amount in millisats (zap request only). This is a string.
.SS lnurl
.IX Subsection "lnurl"
.Vb 1
\&    my $lnurl = $zap\->lnurl;  # \*(Aqlnurl1...\*(Aq or undef
.Ve
.PP
Returns the bech32\-encoded LNURL (zap request only).
.SS e
.IX Subsection "e"
.Vb 1
\&    my $event_id = $zap\->e;  # hex or undef
.Ve
.PP
Returns the zapped event ID.
.SS a
.IX Subsection "a"
.Vb 1
\&    my $coord = $zap\->a;  # \*(Aqkind:pubkey:d\-tag\*(Aq or undef
.Ve
.PP
Returns the addressable event coordinate.
.SS k
.IX Subsection "k"
.Vb 1
\&    my $kind = $zap\->k;  # \*(Aq1\*(Aq or undef
.Ve
.PP
Returns the stringified kind of the target event.
.SS content
.IX Subsection "content"
.Vb 1
\&    my $msg = $zap\->content;
.Ve
.PP
Returns the zap message (zap request) or empty string (zap receipt).
.SS bolt11
.IX Subsection "bolt11"
.Vb 1
\&    my $invoice = $zap\->bolt11;
.Ve
.PP
Returns the bolt11 invoice (zap receipt only).
.SS description
.IX Subsection "description"
.Vb 1
\&    my $json = $zap\->description;
.Ve
.PP
Returns the JSON\-encoded zap request (zap receipt only).
.SS sender
.IX Subsection "sender"
.Vb 1
\&    my $pubkey = $zap\->sender;  # hex or undef
.Ve
.PP
Returns the sender\*(Aqs pubkey from the \f(CW\*(C`P\*(C'\fR tag (zap receipt only).
.SS preimage
.IX Subsection "preimage"
.Vb 1
\&    my $preimage = $zap\->preimage;  # hex or undef
.Ve
.PP
Returns the payment preimage (zap receipt only).
.SH "CLASS METHODS"
.IX Header "CLASS METHODS"
.SS validate_request
.IX Subsection "validate_request"
.Vb 3
\&    Net::Nostr::Zap\->validate_request($event);
\&    Net::Nostr::Zap\->validate_request($event, amount => 21000);
\&    Net::Nostr::Zap\->validate_request($event, receipt_pubkey => $pubkey);
.Ve
.PP
Validates a zap request event per Appendix D of NIP\-57. Croaks on
validation failure. Checks:
.IP "1. Valid Schnorr signature" 4
.IX Item "1. Valid Schnorr signature"
.PD 0
.IP "2. Must have tags" 4
.IX Item "2. Must have tags"
.ie n .IP "3. Exactly one ""p"" tag" 4
.el .IP "3. Exactly one \f(CWp\fR tag" 4
.IX Item "3. Exactly one p tag"
.ie n .IP "4. Zero or one ""e"" tags" 4
.el .IP "4. Zero or one \f(CWe\fR tags" 4
.IX Item "4. Zero or one e tags"
.ie n .IP "5. Should have ""relays"" tag (warns if missing)" 4
.el .IP "5. Should have \f(CWrelays\fR tag (warns if missing)" 4
.IX Item "5. Should have relays tag (warns if missing)"
.ie n .IP "6. ""amount"" tag must match ""amount"" parameter if both present" 4
.el .IP "6. \f(CWamount\fR tag must match \f(CWamount\fR parameter if both present" 4
.IX Item "6. amount tag must match amount parameter if both present"
.ie n .IP "7. ""a"" tag must be a valid event coordinate" 4
.el .IP "7. \f(CWa\fR tag must be a valid event coordinate" 4
.IX Item "7. a tag must be a valid event coordinate"
.ie n .IP "8. Zero or one ""P"" tags; if present and ""receipt_pubkey"" is given, the ""P"" tag value must equal ""receipt_pubkey""" 4
.el .IP "8. Zero or one \f(CWP\fR tags; if present and \f(CWreceipt_pubkey\fR is given, the \f(CWP\fR tag value must equal \f(CWreceipt_pubkey\fR" 4
.IX Item "8. Zero or one P tags; if present and receipt_pubkey is given, the P tag value must equal receipt_pubkey"
.PD
.PP
.Vb 4
\&    my $key = Net::Nostr::Key\->new;
\&    my $event = $zap_req\->to_event(pubkey => $key\->pubkey_hex);
\&    $key\->sign_event($event);
\&    Net::Nostr::Zap\->validate_request($event, amount => 21000);
.Ve
.SS validate_receipt
.IX Subsection "validate_receipt"
.Vb 4
\&    Net::Nostr::Zap\->validate_receipt($event,
\&        nostr_pubkey => $expected,
\&        lnurl        => $recipient_lnurl,
\&    );
.Ve
.PP
Validates a zap receipt event per Appendix F of NIP\-57. Croaks on
validation failure. Checks:
.IP \(bu 4
Receipt pubkey must match \f(CW\*(C`nostr_pubkey\*(C'\fR (the recipient\*(Aqs LNURL
server pubkey)
.IP \(bu 4
Must have \f(CW\*(C`p\*(C'\fR, \f(CW\*(C`bolt11\*(C'\fR, and \f(CW\*(C`description\*(C'\fR tags
.IP \(bu 4
Invoice amount must match the zap request\*(Aqs \f(CW\*(C`amount\*(C'\fR tag if present
.IP \(bu 4
If \f(CW\*(C`lnurl\*(C'\fR is provided and the zap request contains an \f(CW\*(C`lnurl\*(C'\fR
tag, warns if they do not match (SHOULD per spec)
.PP
.Vb 4
\&    Net::Nostr::Zap\->validate_receipt($receipt_event,
\&        nostr_pubkey => $server_pubkey,
\&        lnurl        => $recipient_lnurl,
\&    );
.Ve
.SH FUNCTIONS
.IX Header "FUNCTIONS"
All functions are exportable. None are exported by default.
.SS lud16_to_url
.IX Subsection "lud16_to_url"
.Vb 2
\&    my $url = lud16_to_url(\*(Aqalice@example.com\*(Aq);
\&    # https://example.com/.well\-known/lnurlp/alice
.Ve
.PP
Converts a lightning address (LUD\-16 format) to its LNURL pay endpoint URL.
.PP
.Vb 2
\&    my $url = lud16_to_url(\*(Aqbob@pay.domain.org\*(Aq);
\&    # https://pay.domain.org/.well\-known/lnurlp/bob
.Ve
.SS encode_lnurl
.IX Subsection "encode_lnurl"
.Vb 2
\&    my $lnurl = encode_lnurl(\*(Aqhttps://example.com/.well\-known/lnurlp/alice\*(Aq);
\&    # lnurl1dp68gurn8ghj7...
.Ve
.PP
Encodes a URL as a bech32 string with the \f(CW\*(C`lnurl\*(C'\fR prefix.
.SS decode_lnurl
.IX Subsection "decode_lnurl"
.Vb 2
\&    my $url = decode_lnurl(\*(Aqlnurl1dp68gurn8ghj7...\*(Aq);
\&    # https://example.com/.well\-known/lnurlp/alice
.Ve
.PP
Decodes a bech32\-encoded LNURL back to a URL string. Croaks if the prefix
is not \f(CW\*(C`lnurl\*(C'\fR.
.SS bolt11_amount
.IX Subsection "bolt11_amount"
.Vb 1
\&    my $msats = bolt11_amount(\*(Aqlnbc10u1p3unwfu...\*(Aq);  # 1_000_000
.Ve
.PP
Extracts the amount in millisats from a bolt11 lightning invoice. Returns
\&\f(CW\*(C`undef\*(C'\fR if the invoice has no amount. Croaks if the string is not a valid
bolt11 invoice.
.PP
Amount multiplier suffixes:
.PP
.Vb 4
\&    m = milli (10^\-3 BTC) = 100,000,000 millisats per unit
\&    u = micro (10^\-6 BTC) = 100,000 millisats per unit
\&    n = nano  (10^\-9 BTC) = 100 millisats per unit
\&    p = pico  (10^\-12 BTC) = 0.1 millisats per unit
\&
\&    bolt11_amount(\*(Aqlnbc20m1...\*(Aq)   # 2_000_000_000
\&    bolt11_amount(\*(Aqlnbc2500u1...\*(Aq) # 250_000_000
\&    bolt11_amount(\*(Aqlnbc10u1...\*(Aq)   # 1_000_000
.Ve
.SS callback_url
.IX Subsection "callback_url"
.Vb 5
\&    my $url = callback_url($base_callback,
\&        amount => 21000,
\&        nostr  => $zap_request_event,
\&        lnurl  => \*(Aqlnurl1...\*(Aq,
\&    );
.Ve
.PP
Constructs the HTTP GET URL for sending a zap request to the recipient\*(Aqs
LNURL callback endpoint (Appendix B). The \f(CW\*(C`nostr\*(C'\fR parameter should be a
Net::Nostr::Event object which will be JSON\-encoded and URI\-escaped.
.PP
.Vb 6
\&    my $url = callback_url(\*(Aqhttps://lnurl.example.com/callback\*(Aq,
\&        amount => 21000,
\&        nostr  => $signed_event,
\&        lnurl  => $lnurl,
\&    );
\&    # https://lnurl.example.com/callback?amount=21000&nostr=%7B...%7D&lnurl=lnurl1...
.Ve
.SS calculate_splits
.IX Subsection "calculate_splits"
.Vb 1
\&    my @splits = calculate_splits(@zap_tags);
.Ve
.PP
Calculates zap split percentages from \f(CW\*(C`zap\*(C'\fR tags on an event (Appendix G).
Each tag should be an arrayref: \f(CW\*(C`[\*(Aqzap\*(Aq, $pubkey, $relay, $weight]\*(C'\fR.
.PP
Returns a list of hashrefs with \f(CW\*(C`pubkey\*(C'\fR, \f(CW\*(C`relay\*(C'\fR, and \f(CW\*(C`percentage\*(C'\fR keys.
.PP
If no tags have weights, the split is equal among all recipients. If some
tags have weights and others don\*(Aqt, the weightless tags get 0%.
.PP
.Vb 8
\&    # From spec example: 25%, 25%, 50%
\&    my @splits = calculate_splits(
\&        [\*(Aqzap\*(Aq, $pk1, $relay1, \*(Aq1\*(Aq],
\&        [\*(Aqzap\*(Aq, $pk2, $relay2, \*(Aq1\*(Aq],
\&        [\*(Aqzap\*(Aq, $pk3, $relay3, \*(Aq2\*(Aq],
\&    );
\&    say $splits[0]{percentage};  # 25
\&    say $splits[2]{percentage};  # 50
.Ve
