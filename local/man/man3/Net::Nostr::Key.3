.SH NAME
Net::Nostr::Key \- Secp256k1 keypair management for Nostr
.SH SYNOPSIS
.IX Header "SYNOPSIS"
.Vb 1
\&    use Net::Nostr::Key;
\&
\&    # Generate a new keypair
\&    my $key = Net::Nostr::Key\->new;
\&    say $key\->pubkey_npub;   # npub1...
\&    say $key\->privkey_nsec;  # nsec1...
\&    say $key\->pubkey_hex;    # 64\-char hex (x\-only, BIP\-340)
\&    say $key\->privkey_hex;   # 64\-char hex
\&
\&    # Save and load from file
\&    $key\->save_privkey(\*(Aqmy_key.pem\*(Aq);
\&    my $key = Net::Nostr::Key\->new(privkey => \*(Aqmy_key.pem\*(Aq);
\&
\&    # Create and sign an event
\&    my $event = $key\->create_event(kind => 1, content => \*(Aqhello\*(Aq, tags => []);
\&
\&    # Load from DER data
\&    my $key = Net::Nostr::Key\->new(privkey => \e$der_bytes);
\&    my $key = Net::Nostr::Key\->new(pubkey  => \e$der_bytes);
\&
\&    # Derive from mnemonic seed phrase (NIP\-06)
\&    my $mnemonic = Net::Nostr::Key\->generate_mnemonic;
\&    my $key = Net::Nostr::Key\->from_mnemonic($mnemonic);
\&    my $key = Net::Nostr::Key\->from_mnemonic($mnemonic, account => 1);
.Ve
.SH DESCRIPTION
.IX Header "DESCRIPTION"
Manages secp256k1 keypairs for the Nostr protocol. Supports key generation,
import/export in multiple formats (hex, raw, DER, PEM, NIP\-19 bech32),
file\-based key storage, BIP\-340 Schnorr signatures, and
NIP\-06 <https://github.com/nostr-protocol/nips/blob/master/06.md> key
derivation from BIP\-39 mnemonic seed phrases.
.SH "CLASS METHODS"
.IX Header "CLASS METHODS"
.SS from_mnemonic
.IX Subsection "from_mnemonic"
.Vb 2
\&    my $key = Net::Nostr::Key\->from_mnemonic($mnemonic);
\&    my $key = Net::Nostr::Key\->from_mnemonic($mnemonic, account => 1);
.Ve
.PP
Derives a secp256k1 keypair from a BIP\-39 mnemonic seed phrase using the
NIP\-06 derivation path \f(CW\*(C`m/44\*(Aq/1237\*(Aq/<account>\*(Aq/0/0\*(C'\fR. The \f(CW\*(C`account\*(C'\fR
defaults to \f(CW0\fR.
.PP
.Vb 4
\&    my $mnemonic = \*(Aqleader monkey parrot ring guide accident before fence cannon height naive bean\*(Aq;
\&    my $key = Net::Nostr::Key\->from_mnemonic($mnemonic);
\&    say $key\->privkey_hex;   # 7f7ff03d...
\&    say $key\->pubkey_npub;   # npub1zut...
.Ve
.PP
A basic client can use the default account \f(CW0\fR to derive a single key.
For more advanced use\-cases, increment \f(CW\*(C`account\*(C'\fR to generate practically
infinite keys from the same mnemonic:
.PP
.Vb 2
\&    my $key0 = Net::Nostr::Key\->from_mnemonic($mnemonic);
\&    my $key1 = Net::Nostr::Key\->from_mnemonic($mnemonic, account => 1);
.Ve
.PP
Croaks if the mnemonic is invalid.
.SS generate_mnemonic
.IX Subsection "generate_mnemonic"
.Vb 2
\&    my $mnemonic = Net::Nostr::Key\->generate_mnemonic;
\&    my $mnemonic = Net::Nostr::Key\->generate_mnemonic(bits => 256);
.Ve
.PP
Generates a new BIP\-39 mnemonic seed phrase. The \f(CW\*(C`bits\*(C'\fR parameter controls
the entropy size: \f(CW128\fR (default) produces 12 words, \f(CW256\fR produces
24 words.
.PP
.Vb 3
\&    my $mnemonic = Net::Nostr::Key\->generate_mnemonic;
\&    my $key = Net::Nostr::Key\->from_mnemonic($mnemonic);
\&    say $key\->pubkey_npub;
.Ve
.SH CONSTRUCTOR
.IX Header "CONSTRUCTOR"
.SS new
.IX Subsection "new"
.Vb 4
\&    my $key = Net::Nostr::Key\->new;
\&    my $key = Net::Nostr::Key\->new(privkey => \e$der_bytes);
\&    my $key = Net::Nostr::Key\->new(pubkey  => \e$der_bytes);
\&    my $key = Net::Nostr::Key\->new(privkey => \*(Aqmy_key.pem\*(Aq);
.Ve
.PP
Without arguments, generates a new secp256k1 keypair. Pass \f(CW\*(C`privkey\*(C'\fR or
\&\f(CW\*(C`pubkey\*(C'\fR as a scalar reference to key data (DER or PEM), or as a filename
string to load from a file (PEM or DER format). \f(CW\*(C`privkey\*(C'\fR and \f(CW\*(C`pubkey\*(C'\fR
are mutually exclusive. When only a public key is loaded, signing operations
will fail. Croaks on unknown arguments or if both \f(CW\*(C`privkey\*(C'\fR and \f(CW\*(C`pubkey\*(C'\fR
are provided.
.PP
.Vb 3
\&    # Save a key to a file and load it back
\&    $key\->save_privkey(\*(Aqmy_key.pem\*(Aq);
\&    my $key = Net::Nostr::Key\->new(privkey => \*(Aqmy_key.pem\*(Aq);
.Ve
.SH METHODS
.IX Header "METHODS"
.SS schnorr_sign
.IX Subsection "schnorr_sign"
.Vb 1
\&    my $sig = $key\->schnorr_sign($message);  # 64 raw bytes
.Ve
.PP
Signs the given message using BIP\-340 Schnorr signatures. Returns the
raw 64\-byte signature. Requires a private key to be loaded.
.PP
.Vb 3
\&    my $key = Net::Nostr::Key\->new;
\&    my $sig = $key\->schnorr_sign(\*(Aqhello\*(Aq);
\&    say length($sig);  # 64
.Ve
.SS privkey_loaded
.IX Subsection "privkey_loaded"
.Vb 1
\&    my $bool = $key\->privkey_loaded;
.Ve
.PP
Returns true if a private key is loaded (i.e. signing is possible).
.SS pubkey_loaded
.IX Subsection "pubkey_loaded"
.Vb 1
\&    my $bool = $key\->pubkey_loaded;
.Ve
.PP
Returns true if any key material is loaded (public or private).
.PP
.Vb 3
\&    my $key = Net::Nostr::Key\->new(pubkey => \e$der);
\&    say $key\->pubkey_loaded;   # 1
\&    say $key\->privkey_loaded;  # 0
.Ve
.SS pubkey_hex
.IX Subsection "pubkey_hex"
.Vb 1
\&    my $hex = $key\->pubkey_hex;  # 64\-char lowercase hex
.Ve
.PP
Returns the x\-only public key as a 64\-character hex string, suitable for
use as a Nostr pubkey (BIP\-340 format).
.SS privkey_hex
.IX Subsection "privkey_hex"
.Vb 1
\&    my $hex = $key\->privkey_hex;  # 64\-char lowercase hex
.Ve
.PP
Returns the private key as a 64\-character hex string.
.SS pubkey_npub
.IX Subsection "pubkey_npub"
.Vb 1
\&    my $npub = $key\->pubkey_npub;  # \*(Aqnpub1...\*(Aq
.Ve
.PP
Returns the public key as a NIP\-19 bech32\-encoded \f(CW\*(C`npub\*(C'\fR string.
.PP
.Vb 2
\&    my $key = Net::Nostr::Key\->new;
\&    say $key\->pubkey_npub;  # npub1...
.Ve
.SS privkey_nsec
.IX Subsection "privkey_nsec"
.Vb 1
\&    my $nsec = $key\->privkey_nsec;  # \*(Aqnsec1...\*(Aq
.Ve
.PP
Returns the private key as a NIP\-19 bech32\-encoded \f(CW\*(C`nsec\*(C'\fR string.
.PP
.Vb 2
\&    my $key = Net::Nostr::Key\->new;
\&    say $key\->privkey_nsec;  # nsec1...
.Ve
.SS pubkey_raw
.IX Subsection "pubkey_raw"
.Vb 1
\&    my $raw = $key\->pubkey_raw;  # 65 bytes (04 || x || y)
.Ve
.PP
Returns the uncompressed public key as raw bytes (65 bytes with \f(CW04\fR prefix).
.SS privkey_raw
.IX Subsection "privkey_raw"
.Vb 1
\&    my $raw = $key\->privkey_raw;  # 32 bytes
.Ve
.PP
Returns the private key as 32 raw bytes.
.SS pubkey_der
.IX Subsection "pubkey_der"
.Vb 1
\&    my $der = $key\->pubkey_der;
.Ve
.PP
Returns the public key in DER\-encoded format. Can be passed to a new
Key constructor:
.PP
.Vb 1
\&    my $key2 = Net::Nostr::Key\->new(pubkey => \e$key\->pubkey_der);
.Ve
.SS privkey_der
.IX Subsection "privkey_der"
.Vb 1
\&    my $der = $key\->privkey_der;
.Ve
.PP
Returns the private key in DER\-encoded format.
.PP
.Vb 1
\&    my $key2 = Net::Nostr::Key\->new(privkey => \e$key\->privkey_der);
.Ve
.SS pubkey_pem
.IX Subsection "pubkey_pem"
.Vb 1
\&    my $pem = $key\->pubkey_pem;
.Ve
.PP
Returns the public key in PEM\-encoded format (Base64 with header/footer).
.PP
.Vb 4
\&    say $key\->pubkey_pem;
\&    # \-\-\-\-\-BEGIN PUBLIC KEY\-\-\-\-\-
\&    # ...
\&    # \-\-\-\-\-END PUBLIC KEY\-\-\-\-\-
.Ve
.SS privkey_pem
.IX Subsection "privkey_pem"
.Vb 1
\&    my $pem = $key\->privkey_pem;
.Ve
.PP
Returns the private key in PEM\-encoded format.
.SS save_privkey
.IX Subsection "save_privkey"
.Vb 1
\&    $key\->save_privkey(\*(Aqmy_key.pem\*(Aq);
.Ve
.PP
Saves the private key to the given file path in PEM format with file
mode \f(CW0600\fR (owner read/write only). Croaks if no private key is loaded.
.PP
.Vb 2
\&    my $key = Net::Nostr::Key\->new;
\&    $key\->save_privkey(\*(Aqmy_key.pem\*(Aq);
\&
\&    # Load it back later
\&    my $same_key = Net::Nostr::Key\->new(privkey => \*(Aqmy_key.pem\*(Aq);
.Ve
.SS save_pubkey
.IX Subsection "save_pubkey"
.Vb 1
\&    $key\->save_pubkey(\*(Aqmy_pubkey.pem\*(Aq);
.Ve
.PP
Saves the public key to the given file path in PEM format.
.PP
.Vb 2
\&    my $key = Net::Nostr::Key\->new;
\&    $key\->save_pubkey(\*(Aqmy_pubkey.pem\*(Aq);
\&
\&    my $pub_only = Net::Nostr::Key\->new(pubkey => \*(Aqmy_pubkey.pem\*(Aq);
.Ve
.SS sign_event
.IX Subsection "sign_event"
.Vb 1
\&    my $sig_hex = $key\->sign_event($event);
.Ve
.PP
Verifies that \f(CW\*(C`$event\->pubkey\*(C'\fR matches this key and that the stored
ID matches the event body, then signs with BIP\-340 Schnorr and sets the
event\*(Aqs \f(CW\*(C`sig\*(C'\fR field. Croaks if the pubkey does not match or the ID has
been tampered with. Any existing signature is unconditionally replaced.
Returns the signature as a 128\-character hex string.
.PP
.Vb 6
\&    my $event = Net::Nostr::Event\->new(
\&        pubkey => $key\->pubkey_hex, kind => 1,
\&        content => \*(Aqhello\*(Aq, tags => [],
\&    );
\&    $key\->sign_event($event);
\&    say $event\->sig;  # 128\-char hex
.Ve
.SS create_event
.IX Subsection "create_event"
.Vb 1
\&    my $event = $key\->create_event(kind => 1, content => \*(Aqhello\*(Aq, tags => []);
.Ve
.PP
Convenience method that creates a new Net::Nostr::Event with the
key\*(Aqs public key, signs it, and returns the signed event.
.PP
.Vb 7
\&    my $event = $key\->create_event(
\&        kind    => 1,
\&        content => \*(Aqhello world\*(Aq,
\&        tags    => [[\*(Aqt\*(Aq, \*(Aqnostr\*(Aq]],
\&    );
\&    say $event\->id;   # set
\&    say $event\->sig;  # set
.Ve
.SS constructor_keys
.IX Subsection "constructor_keys"
.Vb 1
\&    my @keys = Net::Nostr::Key\->constructor_keys;  # (\*(Aqprivkey\*(Aq, \*(Aqpubkey\*(Aq)
.Ve
.PP
Returns the list of valid constructor argument names. Used internally
by Net::Nostr to extract key\-related arguments.
